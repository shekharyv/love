        <div
            class="absolute top-10 right-10 w-12 h-12 rounded-full border-4 border-white/20 flex items-center justify-center">
            <span id="countdown" class="text-white font-black">3</span>
        </div>
    </div>

    <!-- Dashboard Camera Modal -->
    <div id="home-camera-modal"
        class="hidden fixed inset-0 z-[100] bg-black flex flex-col items-center justify-center animate-fadeIn">
        <video id="home-video" autoplay playsinline class="w-full h-full object-cover"></video>
        <div class="absolute inset-x-0 bottom-10 flex flex-col items-center space-y-6">
            <div id="home-cam-flash" class="hidden absolute inset-0 bg-white z-50"></div>
            <button id="home-capture-btn"
                class="w-20 h-20 bg-white rounded-full border-4 border-gray-300 shadow-2xl active:scale-95 transition-all flex items-center justify-center">
                <div class="w-16 h-16 bg-brand-pink rounded-full"></div>
            </button>
            <p class="text-white font-black uppercase tracking-[0.2em] text-xs">Tap to Capture ✨</p>
        </div>
        <button onclick="closeHomeCamera()" class="absolute top-10 right-10 text-white text-2xl"><i
                class="fas fa-times"></i></button>
        <canvas id="home-canvas" class="hidden"></canvas>
    </div>

    <!-- Tic Tac Toe Full Screen Modal -->
    <div id="ttt-modal"
        class="hidden fixed inset-0 z-[600] bg-black/95 backdrop-blur-3xl flex items-center justify-center p-6 animate-in fade-in zoom-in duration-300">
        <div class="w-full max-w-md flex flex-col items-center relative">
            <div class="absolute -top-20 -left-20 w-40 h-40 bg-brand-pink/20 blur-[80px] rounded-full"></div>
            <div class="absolute -bottom-20 -right-20 w-40 h-40 bg-cyan-400/20 blur-[80px] rounded-full"></div>

            <div class="mb-10 text-center relative z-10">
                <h2 id="ttt-status-text" class="text-3xl font-black italic mb-2 text-white drop-shadow-lg">Your Turn! 🔥
                </h2>
                <p id="ttt-turn-text" class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-500">Drop an X
                </p>
            </div>

            <div id="ttt-board" class="grid grid-cols-3 gap-4 w-full aspect-square relative z-10">
                <!-- Cells -->
            </div>

            <button onclick="closeTTTModal()"
                class="mt-16 text-gray-600 font-black uppercase text-[9px] tracking-[0.3em] hover:text-brand-pink transition-all flex items-center space-x-2">
                <i class="fas fa-times-circle"></i>
                <span>Close Game 🚪</span>
            </button>
        </div>
    </div>

    <script>
        // --- TIC TAC TOE SYSTEM ---
        let tttCurrentGame = null;
        let tttInterval = null;

        async function startTTT() {
            try {
                const res = await fetch('/api/ttt/create', { method: 'POST' });
                const game = await res.json();
                openTTTModal(game);
                showToast("Challenge sent to Partner! 🎮");
            } catch (e) { showToast("Failed to start game ❌"); }
        }

        async function loadTTTGame() {
            try {
                const res = await fetch('/api/ttt/active');
                const game = await res.json();
                if (game) {
                    if (!tttCurrentGame) openTTTModal(game);
                    renderTTTBoard(game);
                } else if (tttCurrentGame) {
                    closeTTTModal();
                }
            } catch (e) { }
        }

        function openTTTModal(game) {
            tttCurrentGame = game;
            document.getElementById('ttt-modal').classList.remove('hidden');
            renderTTTBoard(game);
            if (!tttInterval) tttInterval = setInterval(loadTTTGame, 2000);
        }

        function closeTTTModal() {
            document.getElementById('ttt-modal').classList.add('hidden');
            tttCurrentGame = null;
            clearInterval(tttInterval);
            tttInterval = null;
        }

        function renderTTTBoard(game) {
            tttCurrentGame = game;
            const modal = document.getElementById("ttt-modal");
            const board = document.getElementById("ttt-board");
            const statusText = document.getElementById("ttt-status-text");
            const turnText = document.getElementById("ttt-turn-text");

            board.innerHTML = "";
            game.board.forEach((cell, i) => {
                const div = document.createElement('div');
                div.onclick = () => makeTTTMove(i);
                div.className = `h-full flex items-center justify-center text-5xl font-black rounded-[2rem] cursor-pointer transition-all duration-300 transform active:scale-95 ${cell === 'X' ? 'text-brand-pink bg-brand-pink/10 shadow-[inner_0_0_20px_rgba(225,29,72,0.2)] border border-brand-pink/30' :
                    cell === 'O' ? 'text-cyan-400 bg-cyan-400/10 shadow-[inner_0_0_20px_rgba(34,211,238,0.2)] border border-cyan-400/30' :
                        'bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20'
                    }`;
                div.innerHTML = cell || "";
                board.appendChild(div);
            });

            if (game.status === 'finished') {
                const win = game.winner;
                const isWinner = win === USER_ID;
                const isDraw = !win;

                if (isWinner) {
                    statusText.innerText = "VICTORY! 🏁🏆";
                    statusText.classList.add('text-green-500');
                    turnText.innerText = "You are smarter! +20 Points ❤️";
                    modal.classList.add('winner-glow');
                    triggerConfetti();
                } else if (isDraw) {
                    statusText.innerText = "DRAW! 🤝";
                    turnText.innerText = "Great minds think alike!";
                } else {
                    statusText.innerText = "DEFEAT... 💔";
                    statusText.classList.add('text-red-500');
                    turnText.innerText = "Better luck next time, Loser! 😏";
                    modal.classList.add('loser-shake');
                    navigator.vibrate?.([100, 50, 100]);
                }

                setTimeout(() => {
                    closeTTTModal();
                    modal.classList.remove('winner-glow', 'loser-shake');
                    statusText.classList.remove('text-green-500', 'text-red-500');
                }, 6000);
            } else {
                const isMyTurn = game.turn === USER_ID;
                statusText.innerText = isMyTurn ? "Your Turn! 🔥" : "Waiting for Partner... ⏳";
                turnText.innerText = isMyTurn ? "Tap to place mark" : "Partner is thinking";
            }
        }

        function triggerConfetti() {
            for (let i = 0; i < 40; i++) {
                const c = document.createElement('div');
                c.className = 'confetti';
                c.style.left = Math.random() * 100 + 'vw';
                c.style.backgroundColor = ['#E11D48', '#FF69B4', '#DA70D6', '#06b6d4'][Math.floor(Math.random() * 4)];
                c.style.animationDuration = (Math.random() * 2 + 2) + 's';
                c.style.opacity = Math.random();
                document.body.appendChild(c);
                setTimeout(() => c.remove(), 4000);
            }
        }

        async function makeTTTMove(index) {
            if (!tttCurrentGame || tttCurrentGame.turn !== USER_ID || tttCurrentGame.status !== 'playing') return;
            try {
                const res = await fetch('/api/ttt/move', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ gameId: tttCurrentGame._id, index })
                });
                const game = await res.json();
                if (game.error) return showToast(game.error);
                renderTTTBoard(game);
                navigator.vibrate?.([60]);
            } catch (e) { }
        }

        // Socket listeners for instant updates
        if (typeof socket !== 'undefined') {
            socket.on('ttt-invite', (data) => {
                showToast(`${data.senderName} challenged you to TTT! 🎮`);
                loadTTTGame();
            });
            socket.on('ttt-move', (game) => {
                renderTTTBoard(game);
            });
        }

        // --- REAL TIME SNAP SYSTEM ---
        let currentSnap = null;

        async function loadSnap() {
            try {
                const res = await fetch('/api/unread-snap');
                const data = await res.json();

                const card = document.getElementById("snapCard");
                const text = document.getElementById("snapText");

                if (!data) {
                    card.classList.add('hidden');
                    return;
                }

                currentSnap = data;
                card.classList.remove("hidden");
                text.innerText = `"${data.senderId === PARTNER_ID ? (currentPartner.name || "Partner") : "Partner"} sent: ${data.text || "A new snap! 📸"}"`;
            } catch (e) {
                console.error("Snap load failed", e);
            }
        }

        async function openSnap() {
            if (!currentSnap) return;

            const viewer = document.getElementById("snapViewer");
            const img = document.getElementById("snapImage");
            const countdownEl = document.getElementById("countdown");

            img.src = currentSnap.text; // Message stored image in 'text' field currently
            viewer.classList.remove("hidden");

            // Mark as opened in backend
            await fetch("/api/open-snap", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ snapId: currentSnap._id })
            });

            // ⏳ 3 Sec Countdown
            let left = 3;
            const timer = setInterval(() => {
                left--;
                countdownEl.innerText = left;
                if (left <= 0) {
                    clearInterval(timer);
                    viewer.classList.add("hidden");
                    img.src = "";
                    document.getElementById("snapCard").classList.add("hidden");
                    currentSnap = null;
                }
            }, 1000);

            navigator.vibrate?.(100);
        }

        // --- LOVE SCORE SYSTEM ---
        async function loadLoveScore() {
            try {
                const res = await fetch('/api/today-stats');
                const data = await res.json();

                const scoreEl = document.getElementById('home-love-score');
                const insightEl = document.getElementById('home-score-insight');

                if (data.score) {
                    // Smooth counter effect
                    let start = 0;
                    const end = data.score;
                    const duration = 1000;
                    const stepTime = Math.abs(Math.floor(duration / end));

                    const timer = setInterval(() => {
                        start++;
                        if (scoreEl) scoreEl.innerText = start;
                        if (start >= end) clearInterval(timer);
                    }, stepTime);

                    if (insightEl) insightEl.innerText = `"${data.insight}"`;
                }
            } catch (e) {
                console.error("Love Score failed", e);
            }
        }

        // Initialize and Set Interval
        loadLoveScore();
        setInterval(loadLoveScore, 10000);

        // Auto Load Snaps every few seconds
        setInterval(loadSnap, 3000);
    </script>
    <!-- SYNC SUCCESS OVERLAY -->
    <div id="syncSuccessScreen" class="sync-success-overlay">
        <div class="heart-merge">
            <i class="fas fa-heart merging-heart heart-left"></i>
            <i class="fas fa-heart merging-heart heart-right"></i>
            <div class="pulse-burst"></div>
        </div>
        <h2 class="text-4xl font-black italic mt-10 tracking-tighter animate-bounce text-white">LOVE SYNCED! ❤️</h2>
        <p class="text-gray-400 font-black uppercase tracking-[0.4em] text-[10px] mt-4">Connecting your lives together...</p>
    </div>
</body>

</html>