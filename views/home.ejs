    <script>
        // Floating Hearts Gen
        const container = document.getElementById('heart-container');
        function createHeart() {
            const heart = document.createElement('div'); heart.classList.add('heart');
            heart.innerHTML = '<i class="fas fa-heart"></i>';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.fontSize = Math.random() * 10 + 10 + 'px';
            heart.style.animationDuration = Math.random() * 5 + 5 + 's';
            heart.style.animationDelay = -Math.random() * 10 + 's';
            container.appendChild(heart);
            setTimeout(() => heart.remove(), 10000);
        }
        setInterval(createHeart, 1000);

        // --- Master Dashboard Loader ---
        async function loadDashboard() {
            try {
                // 1. Fetch Partner
                const partnerRes = await fetch('/api/partner');
                const partner = await partnerRes.json();
                const pStatus = partner.status || 'Offline';
                const pName = partner.name || 'Partner';
                document.getElementById('partner-status').innerText = pStatus;
                document.getElementById('header-partner-name').innerText = pName;
                document.getElementById('user-streak').innerText = `${partner.streak} Days`;

                // Update Status Indicator & Vibe
                const statusIndicator = document.getElementById('status-indicator');
                const currentVibe = document.getElementById('current-vibe');
                if (pStatus === 'Online') {
                    statusIndicator.classList.remove('bg-gray-500');
                    statusIndicator.classList.add('bg-green-500');
                    currentVibe.innerText = 'Syncing Live ❤️';
                    currentVibe.classList.replace('text-gray-400', 'text-green-400');
                } else {
                    statusIndicator.classList.remove('bg-green-500');
                    statusIndicator.classList.add('bg-gray-500');
                    currentVibe.innerText = 'Vibing Offline';
                    currentVibe.classList.replace('text-green-400', 'text-gray-400');
                }

                // Partner's Mood logic
                const pMoodEl = document.getElementById('header-partner-mood');
                const pEmojiEl = document.getElementById('partner-mood-emoji');

                // Update Names
                if (document.getElementById('partnerLabel')) document.getElementById('partnerLabel').innerText = partner.name;

                if (partner.partnerMood && partner.partnerMood !== "None") {
                    document.getElementById("partnerMoodText").innerText = `${partner.name} is feeling ${partner.partnerMood} today`;
                    pMoodEl.classList.remove('hidden');
                    pEmojiEl.innerText = partner.partnerMood;
                    pEmojiEl.classList.remove('grayscale');
                } else {
                    pMoodEl.classList.add('hidden');
                    pEmojiEl.innerText = '❓';
                    pEmojiEl.classList.add('grayscale');
                }


                // Update My Mood on Load
                const myEmojiEl = document.getElementById('user-mood-emoji');
                if (partner.myMood && partner.myMood !== "None") {
                    myEmojiEl.innerText = partner.myMood;
                    myEmojiEl.classList.remove('grayscale');
                    document.getElementById('sync-progress').style.height = '100%';
                }

                // 2. Fetch Love Score
                const scoreRes = await fetch('/api/love-score');
                const scoreData = await scoreRes.json();
                document.getElementById('home-love-score').innerText = scoreData.score;
                document.getElementById('score-progress').style.width = (scoreData.score % 100) + '%';

                // 3. Fetch Challenge
                const challengeRes = await fetch('/api/daily-challenge');
                const challengeData = await challengeRes.json();
                document.getElementById('challenge-text').innerText = `"${challengeData.challenge}"`;

                // 4. Fetch Last Snap
                const snapRes = await fetch('/api/last-snap');
                const snapData = await snapRes.json();
                if (snapData.snap.timestamp) {
                    document.getElementById('last-snap-preview').innerHTML = `
                        <div class="absolute inset-0 bg-brand-pink/20 blur-md"></div>
                        <p class="relative z-10 text-[10px] font-black uppercase text-brand-pink">Received ${new Date(snapData.snap.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })} 👀</p>
                    `;
                }

                // 5. Quiz Status
                await checkQuizStatus();

                // 6. Love Reminder
                const reminderRes = await fetch('/api/love-reminder');
                const reminderData = await reminderRes.json();
                if (reminderData.show) {
                    document.getElementById('suggestion-text').innerText = reminderData.suggestion;
                }

                // Greeting logic
                const hrs = new Date().getHours();
                const welcome = document.getElementById('welcome-text');
                if (hrs < 12) welcome.innerText = "Good Morning";
                else if (hrs < 17) welcome.innerText = "Good Afternoon";
                else welcome.innerText = "Good Evening";

                // --- NEW: Behavior Analytics Sync ---
                const behaviorRes = await fetch('/api/insights/behavior');
                const behaviorData = await behaviorRes.json();
                if (behaviorData.user) {
                    document.getElementById('home-speed').innerText = behaviorData.user.speed;
                    document.getElementById('home-speed-vs').innerText = `vs ${behaviorData.partner.speed}`;
                    document.getElementById('home-snaps').innerText = `${behaviorData.user.snaps}/d`;
                    document.getElementById('home-accuracy').innerText = `${behaviorData.user.accuracy}%`;

                    // Sync Level System
                    const rank = behaviorData.rank;
                    if (rank) {
                        document.getElementById('home-lvl-text').innerText = `Level ${rank.level}`;
                        document.getElementById('home-lvl-title').innerText = rank.title;
                        document.getElementById('home-exp-text').innerText = `Exp: ${rank.exp} / ${rank.nextExp}`;
                        document.getElementById('home-lvl-percent').innerText = `${rank.percent}% to next level`;
                        document.getElementById('home-lvl-bar').style.width = `${rank.percent}%`;
                    }

                    // Sync Love Score Progress
                    const score = behaviorData.userScore || 0;
                    document.getElementById('home-lvl-score-val').innerText = `${score}%`;
                    const bars = document.getElementById('home-lvl-bars').children;
                    for(let i=0; i<bars.length; i++) {
                       bars[i].style.height = `${(score/100) * (50 + i*10)}%`;
                    }
                    const msg = document.getElementById('home-lvl-score-msg');
                    if (score > 80) msg.innerText = "Soulmate level energy! 🔥😍";
                    else if (score > 50) msg.innerText = "Great job! Keep the rhythm going ❤️";
                    else msg.innerText = "Time to sync more with your partner! 😊";
                }

            } catch (err) {
                console.error("Dashboard Sync Failed:", err);
            } finally {
                setTimeout(() => {
                    document.getElementById('loader').style.opacity = '0';
                    document.getElementById('loader').style.visibility = 'hidden';
                }, 800);
            }
        }

        window.onload = loadDashboard;

        // Logic Functions
        function vibrateBtn() {
            navigator.vibrate?.(50);
            document.getElementById('snap-btn').classList.add('vibrate');
            setTimeout(() => {
                document.getElementById('snap-btn').classList.remove('vibrate');
                window.location.href = '/camera';
            }, 500);
        }

        async function setMood(emoji) {
            const userEmoji = document.getElementById('user-mood-emoji');
            const partnerEmoji = document.getElementById('partner-mood-emoji');
            const syncStatus = document.getElementById('mood-sync-status');
            const progress = document.getElementById('sync-progress');
            const badge = document.getElementById('mood-match-badge');

            userEmoji.innerText = emoji;
            userEmoji.classList.remove('grayscale');
            progress.style.height = '100%';

            await fetch('/api/activity', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ type: 'mood', content: emoji })
            });

            if (emoji === partnerEmoji.innerText) {
                badge.classList.remove('hidden');
                syncStatus.innerText = "You both are in sync today! ❤️";
                syncStatus.classList.add('text-brand-pink');
                document.getElementById('mood-widget').classList.add('shadow-[0_0_40px_rgba(225,29,72,0.2)]');
            } else {
                badge.classList.add('hidden');
                syncStatus.innerText = `You: ${emoji} | Partner: ${partnerEmoji.innerText}`;
                syncStatus.classList.remove('text-brand-pink');
            }

            showToast("Mood Shared! ✨");
        }

        async function completeChallenge() {
            const btn = document.getElementById('challenge-btn');
            const res = await fetch('/api/complete-challenge', { method: 'POST' });
            const data = await res.json();

            btn.innerHTML = 'Challenge Completed! 🏆';
            btn.classList.replace('bg-white', 'bg-green-500');
            btn.classList.add('text-white');
            showToast(`+${data.bonus} Love Points! 🏆`);
            loadDashboard();
            // Refresh dashboard every 10 seconds for real-time vibe
            if (!window.dashInterval) window.dashInterval = setInterval(loadDashboard, 10000);
            // Refresh score
        }

        const surprises = [
            "A surprise dinner at your favorite place! 🍽️",
            "I dare you to text her a romantic poem right now! 📜",
            "What was the moment you knew you loved her? ❤️",
            "Free hug coupon! (Valid for tonight) 🤗",
            "New Badge Unlocked: Ultimate Sweetheart 💖"
        ];
        function getSurprise() {
            const gift = surprises[Math.floor(Math.random() * surprises.length)];
            alert(`🎁 SURPRISE: \n\n${gift}`);
            showToast("Surprise Unlocked! 🎀");
        }

        async function sendLove(action) {
            let emoji = '❤️';
            if(action.includes('Kiss')) emoji = '😘';
            if(action.includes('Hug')) emoji = '🤗';

            // Send via Socket for instant rain
            if (typeof socket !== 'undefined' && socket.connected) {
                socket.emit('love-action', { coupleId: [USER_ID, PARTNER_ID].sort().join('_'), emoji, senderName: '<%= user.name %>' });
            }

            await fetch('/api/send-quick-message', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: action })
            });
            showToast(`${action} Sent ❤️`);
            navigator.vibrate?.(40);
        }

        function triggerRain(emoji) {
            for (let i = 0; i < 40; i++) {
                setTimeout(() => {
                    const e = document.createElement('div');
                    e.innerText = emoji;
                    e.style.position = 'fixed';
                    e.style.top = '-50px';
                    e.style.left = Math.random() * 100 + 'vw';
                    e.style.fontSize = (Math.random() * 20 + 20) + 'px';
                    e.style.zIndex = '100000';
                    e.style.pointerEvents = 'none';
                    e.style.transition = 'all 2.5s linear';
                    document.body.appendChild(e);
                    e.offsetHeight; // reflow
                    e.style.top = '110vh';
                    e.style.transform = `rotate(${Math.random() * 360}deg)`;
                    setTimeout(() => e.remove(), 3000);
                }, i * 60);
            }
        }

        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.innerHTML = msg;
            toast.style.display = 'block';
            setTimeout(() => { toast.style.display = 'none'; }, 2000);
        }


        const sweetMessages = [
            "Just wanted to say I love you! ❤️",
            "Thinking of you right now... ✨",
            "Miss your smile already! 😘",
            "You are my favorite person! ❤️",
            "Can't wait to see you soon! 🏹",
            "You make my heart skip a beat! 💓",
            "Sending you a million virtual hugs! 🤗",
            "You are the best thing that ever happened to me! 💖"
        ];

        async function getSuggestion() {
            const btn = document.querySelector('button[onclick="getSuggestion()"]');
            const originalText = btn.innerHTML;
            const message = sweetMessages[Math.floor(Math.random() * sweetMessages.length)];

            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Sending...';
            btn.disabled = true;

            try {
                await fetch('/api/send-quick-message', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: message })
                });

                showToast("Sweet message sent! 🏹❤️");
                btn.innerHTML = 'Sent! ✨';
                btn.classList.add('bg-brand-pink', 'text-white');

                // Vibrate
                navigator.vibrate?.([40, 20, 40]);

                setTimeout(() => {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                    btn.classList.remove('bg-brand-pink', 'text-white');
                }, 3000);
            } catch (e) {
                showToast("Failed to send! ❌");
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        let pollInterval;
    </script>


    <!-- Socket.io Sync -->
    <script>
        function createNoopSocket() {
            return {
                on: () => { },
                emit: () => { },
                connected: false
            };
        }

        function createSocketClient() {
            if (typeof io !== 'function') return createNoopSocket();
            try {
                const s = io({
                    path: '/socket.io',
                    transports: ['websocket'],
                    upgrade: false,
                    withCredentials: true,
                    reconnection: true,
                    reconnectionAttempts: 5,
                    timeout: 10000
                });

                s.on('connect_error', (err) => {
                    console.warn('Realtime temporarily unavailable:', err.message);
                });
                return s;
            } catch (err) {
                console.warn('Socket init failed:', err.message);
                return createNoopSocket();
            }
        }

        const socket = createSocketClient();
        let USER_ID = "<%= user._id %>";
        let PARTNER_ID = "<%= user.partnerId %>";
        let currentPartner = { name: "<%= user.partnerName || 'Partner' %>", profileImage: '/images/partner-avatar.png' };

        // --- NOTIFICATION PERMISSION ---
        async function requestNotificationPermission() {
            if ('Notification' in window) {
                if (Notification.permission !== 'granted' && Notification.permission !== 'denied') {
                    await Notification.requestPermission();
                }
            }
        }
        function showWebNotification(msg) {
            if (Notification.permission === 'granted') {
                const title = `${msg.user} ❤️`;
                const options = {
                    body: msg.type === 'image' ? 'Sent a new snap! 📸' : (msg.type === 'audio' ? 'Sent a voice note 🎤' : msg.text),
                    icon: currentPartner.profileImage || '/images/partner-avatar.png',
                    vibrate: [200, 100, 200],
                    tag: 'chat-msg'
                };
                new Notification(title, options);
            }
        }
        socket.on('chat message', (msg) => {
            if (msg.senderId !== USER_ID) {
                showWebNotification(msg);
                if ('vibrate' in navigator) navigator.vibrate([100, 50, 100]);
                showToast(`New message from ${msg.user}! ❤️`);
            }
        });
        requestNotificationPermission();

        socket.on('trigger-rain', (data) => {
            triggerRain(data.emoji);
            showToast(`${data.senderName} sent you a ${data.emoji}! ❤️`);
        });

        async function initSync() {
            try {
                const res = await fetch('/api/partner');
                const p = await res.json();
                USER_ID = "<%= user._id %>";
                PARTNER_ID = p.partnerId;
                currentPartner = p;

                // Load My Initial Mood
                const myEmoji = document.getElementById('user-mood-emoji');
                if (myEmoji) {
                    const myMood = "<%= user.mood %>";
                    if (myMood && myMood !== "❓") {
                        myEmoji.innerText = myMood;
                        myEmoji.classList.remove('grayscale');
                    }
                }

                // Load active games or status
                loadTTTGame();
                loadLoveScore();
                loadPartnerMood();

                // Update Partner Label in Widget
                const partnerLabel = document.getElementById('partnerLabel');
                if (partnerLabel && p.name !== "Unpaired") {
                    partnerLabel.innerText = p.name;
                }

                if (PARTNER_ID) {
                    socket.emit('join', { userId: USER_ID, partnerId: PARTNER_ID });
                    loadPartnerMood(); // Initial load
                }
            } catch (e) { console.error("Init Error:", e); }
        }

        // --- TRUTH OR DARE SYSTEM ---
        let isManual = false;
        let currentChallenge = "";

        function toggleManualMode() {
            isManual = !isManual;
            const toggleBtn = document.getElementById('manual-toggle');
            const display = document.getElementById('game-prompt');
            const input = document.getElementById('manual-input');
            const aiControls = document.getElementById('ai-controls');
            const sendBtn = document.getElementById('game-send-btn');

            if (isManual) {
                toggleBtn.innerText = "Manual: ON ✍️";
                toggleBtn.classList.replace('text-gray-500', 'text-purple-400');
                display.classList.add('hidden');
                input.classList.remove('hidden');
                aiControls.classList.add('hidden');
                sendBtn.classList.remove('opacity-0', 'pointer-events-none');
                sendBtn.classList.add('opacity-100', 'pointer-events-auto');
                input.focus();
            } else {
                toggleBtn.innerText = "Manual: OFF";
                toggleBtn.classList.replace('text-purple-400', 'text-gray-500');
                display.classList.remove('hidden');
                input.classList.add('hidden');
                aiControls.classList.remove('hidden');
                if (!currentChallenge) {
                    sendBtn.classList.add('opacity-0', 'pointer-events-none');
                }
            }
        }

        let currentGameLevel = 4;

        function setGameLevel(lvl, btn) {
            currentGameLevel = lvl;
            document.querySelectorAll('.game-lvl-btn').forEach(b => {
                b.classList.remove('bg-gradient-to-r', 'from-brand-pink', 'to-purple-600', 'text-white', 'border-white/10', 'shadow-[0_0_20px_rgba(225,29,72,0.3)]', 'rounded-[1.2rem]');
                b.classList.add('bg-transparent', 'text-gray-500', 'border-transparent', 'shadow-none', 'rounded-2xl');
                
                // Keep colors for deep level context
                if(b.innerText.includes('MEDIUM')) b.classList.replace('text-gray-500', 'text-[#9333EA]');
                if(b.innerText.includes('DEEP')) b.classList.replace('text-gray-500', 'text-blue-400/80');
            });

            btn.classList.remove('bg-transparent', 'text-gray-500', 'text-[#9333EA]', 'text-blue-400/80', 'border-transparent', 'shadow-none', 'rounded-2xl');
            btn.classList.add('bg-gradient-to-r', 'from-brand-pink', 'to-purple-600', 'text-white', 'border-white/10', 'shadow-[0_0_20px_rgba(225,29,72,0.3)]', 'rounded-[1.2rem]');
            
            navigator.vibrate?.(40);
        }

        function getFallbackQuestion(type, levelNum) {
            const levelMap = { "1": "normal", "2": "medium", "3": "deep", "4": "naughty" };
            const lvl = levelMap[levelNum] || "normal";
            const fallbacks = {
                truth: {
                    normal: ["Tum mujhe sabse cute kab lagte ho? 💖", "Humari pehli date ki sabse cute baat? ✨", "Aaaj tumhare mind me mere liye pehla thought kya tha? 💭"],
                    medium: ["Meri kaunsi cheez tumhe sabse zyada tease karti hai? 👀", "Tumhe humare relationship me kya sabse special lagta hai? ❤️", "Describe our first kiss in 3 words 💋"],
                    deep: ["Kab tumne feel kiya ki tum mujhse pyaar karte ho? ✨", "Humara future tum kaise imagine karte ho? 🏠", "Tumne mere baare me aaj kya miss kiya? ❤️"],
                    naughty: ["Describe what you'd do to me in 3 words 🫦", "What is your biggest secret fantasy about me? 🔥", "Muujhe batao tum abhi kya feel kar rahe ho? 😏"]
                },
                dare: {
                    normal: ["Send me a sweet voice note right now 😘", "Take a cute selfie with a heart sign 📸❤️", "Say 'I Love You' in your softest voice 🎤"],
                    medium: ["Send a flirty message that makes me blush 🔥", "Send a snap biting your lip right now 🫦", "Tell me one thing you'd do to me if I were there 👀"],
                    deep: ["Record a video telling me why you love me ❤️", "Send a picture of the thing that reminds you of me 🏠", "Voice note: Say something deep and emotional ✨"],
                    naughty: ["Send a bold/spicy snap for my eyes only 🫦🥵", "Describe our most intimate moment in a voice note 🔥", "Send me a text that we'll have to delete later 😏"]
                }
            };
            const list = fallbacks[type][lvl];
            return list[Math.floor(Math.random() * list.length)];
        }

        async function generateGame(type, retryCount = 1) {
            const display = document.getElementById('game-prompt');
            const sendBtn = document.getElementById('game-send-btn');

            display.innerText = "Thinking something cute for you... 💖✨";
            display.classList.add('animate-pulse');
            
            const controller = new AbortController();
            const timeout = setTimeout(() => controller.abort(), 6000); // 6s timeout

            try {
                const res = await fetch(`/api/generate-challenge?type=${type}&level=${currentGameLevel}`, {
                    signal: controller.signal
                });
                clearTimeout(timeout);
                const data = await res.json();

                if (data.question) {
                    // Strict Validation: Dares shouldn't be questions, Truths should be
                    const isDare = type === 'dare';
                    const hasQuestionMark = data.question.includes('?');

                    if ((isDare && hasQuestionMark) || (!isDare && !hasQuestionMark)) {
                        if (retryCount > 0) {
                            console.log(`AI mixed up Truth/Dare! Retrying...`);
                            return generateGame(type, retryCount - 1);
                        }
                    }
                    currentChallenge = data.question;
                } else {
                    throw new Error("AI failed to return question");
                }
            } catch (e) {
                clearTimeout(timeout);
                if (retryCount > 0) {
                    console.log(`AI failed or timed out! Retrying... (${retryCount} left)`);
                    return generateGame(type, retryCount - 1);
                }
                console.log("AI failed all retries, using fallback");
                currentChallenge = getFallbackQuestion(type, currentGameLevel);
            }

            // Finally show whatever we got (AI or Fallback)
            display.innerText = `"${currentChallenge}"`;
            display.classList.remove('animate-pulse');
            display.classList.add('animate-in', 'zoom-in', 'duration-500');

            sendBtn.classList.remove('opacity-0', 'pointer-events-none');
            sendBtn.classList.add('opacity-100', 'pointer-events-auto');
            navigator.vibrate?.([40, 20, 40]);
        }

        async function sendGameChallenge() {
            let finalChallenge = isManual ? document.getElementById('manual-input').value.trim() : currentChallenge;

            if (!finalChallenge) return showToast("Challenge empty! 😅");

            const btn = document.getElementById('game-send-btn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Sending...';
            btn.disabled = true;

            try {
                await fetch('/api/send-quick-message', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: `GAME CHALLENGE: ${finalChallenge}` })
                });
                showToast("Challenge Sent! 🎭");
                btn.innerHTML = 'Challenge Sent ✅';

                if (isManual) document.getElementById('manual-input').value = "";

                setTimeout(() => {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }, 3000);
            } catch (e) {
                showToast("Failed to send! ❌");
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        initSync();

        async function loadPartnerMood() {
            if (!PARTNER_ID) return;
            try {
                const res = await fetch('/api/partner-mood');
                const data = await res.json();
                updatePartnerMoodUI(data.mood, data.name);
            } catch (e) { console.error("Mood Load Error:", e); }
        }

        function updatePartnerMoodUI(mood, name) {
            const headerDisplay = document.getElementById('partnerMood');
            const widgetDisplay = document.getElementById('partner-mood-emoji');
            const syncStatus = document.getElementById('mood-sync-status');

            const moodValue = (mood && mood !== "❓") ? mood : "Waiting... 💭";

            if (headerDisplay) headerDisplay.innerText = moodValue;

            if (widgetDisplay) {
                widgetDisplay.innerText = (mood && mood !== "❓") ? mood : "❓";
                widgetDisplay.classList.toggle('grayscale', !mood || mood === "❓");
                if (mood && mood !== "❓") widgetDisplay.classList.add('animate-bounce');
                setTimeout(() => widgetDisplay.classList.remove('animate-bounce'), 2000);
            }

            if (syncStatus && name) {
                syncStatus.innerText = mood && mood !== "❓" ? `${name} is feeling ${mood} today ❤️` : `Waiting for ${name} to share mood...`;
            }
        }

        socket.on('partner mood update', (data) => {
            updatePartnerMoodUI(data.mood, "Partner");
        });

        async function setMood(mood) {
            if (!PARTNER_ID) return alert("Connect with your partner first! ❤️");

            // Update my emoji visually
            const myEmoji = document.getElementById('user-mood-emoji');
            if (myEmoji) {
                myEmoji.innerText = mood;
                myEmoji.classList.remove('grayscale');
            }

            try {
                const res = await fetch('/api/set-mood', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mood })
                });
                const data = await res.json();
                if (data.success) {
                    showToast(`Mood: ${mood} Shared! ✨`);
                }
            } catch (e) { console.error("Set Mood Error:", e); }
        }

        // Initialize polling safety net
        setInterval(loadPartnerMood, 5000);

        // --- SNAP SYSTEM ---
        let homeStream, homeCapturedImage = null;
        let autoCaptureTimer;

        async function openHomeCamera() {
            try {
                homeStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } });
                document.getElementById('home-video').srcObject = homeStream;
                document.getElementById('home-camera-modal').classList.remove('hidden');
                showToast("Auto-capture in 2s... Get ready! 📸");
                autoCaptureTimer = setTimeout(captureHomePhoto, 2000);
            } catch (e) { alert("Camera Access Required! 📸"); }
        }

        function captureHomePhoto() {
            clearTimeout(autoCaptureTimer);
            const video = document.getElementById('home-video');
            const canvas = document.getElementById('home-canvas');
            const flash = document.getElementById('home-cam-flash');
            if (!video.srcObject) return;
            flash.classList.remove('hidden');
            setTimeout(() => flash.classList.add('hidden'), 100);
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            homeCapturedImage = canvas.toDataURL('image/jpeg', 0.6);
            closeHomeCamera();
            const preview = document.getElementById('home-preview');
            if (preview) { preview.src = homeCapturedImage; preview.classList.remove('hidden'); }
            showToast("Snap Captured! ❤️ Ready to send.");
            document.getElementById('home-send-btn').innerHTML = "Send Now 🚀";
        }

        function uploadHomeImage() {
            const input = document.getElementById('home-file-input');
            input.click();
            input.onchange = () => {
                const file = input.files[0];
                const reader = new FileReader();
                reader.onload = () => {
                    homeCapturedImage = reader.result;
                    const preview = document.getElementById('home-preview');
                    if (preview) { preview.src = homeCapturedImage; preview.classList.remove('hidden'); }
                    showToast("Photo Uploaded! 📁 Ready to send.");
                    document.getElementById('home-send-btn').innerHTML = "Send Now 🚀";
                };
                reader.readAsDataURL(file);
            };
        }

        function closeHomeCamera() {
            clearTimeout(autoCaptureTimer);
            if (homeStream) homeStream.getTracks().forEach(t => t.stop());
            document.getElementById('home-camera-modal').classList.add('hidden');
        }

        async function sendHomeSnap() {
            if (!homeCapturedImage) return openHomeCamera();
            if (!PARTNER_ID) return alert("Connect with your partner first! ❤️");
            const btn = document.getElementById('home-send-btn');
            btn.innerHTML = 'Sending... ⏳';
            btn.disabled = true;
            try {
                const res = await fetch('/api/send-snap', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ image: homeCapturedImage, coupleId: [USER_ID, PARTNER_ID].sort().join('_') })
                });
                if ((await res.json()).success) {
                    showToast("Snap Sent! 💖");
                    btn.innerHTML = "Send Snap ❤️";
                    btn.disabled = false;
                    homeCapturedImage = null;
                    if (document.getElementById('home-preview')) document.getElementById('home-preview').classList.add('hidden');
                }
            } catch (e) { showToast("Failed! ❌"); btn.disabled = false; }
        }

        async function loadLastSnap() {
            if (!PARTNER_ID) return;
            try {
                const res = await fetch('/api/get-snaps');
                const snaps = await res.json();
                const preview = document.getElementById('last-snap-preview');
                if (snaps.length > 0) {
                    preview.innerHTML = `<img src="${snaps[0].text}" class="w-full h-full object-cover rounded-2xl animate-in zoom-in duration-500" />`;
                }
            } catch (e) { }
        }

        async function checkAttention() {
            if (!PARTNER_ID) return;
            try {
                const res = await fetch('/api/attention-alert');
                const data = await res.json();
                const alertBox = document.getElementById('alertBox');
                if (data.show) {
                    alertBox.classList.remove('hidden');
                    document.getElementById('alertText').innerText = `You ignored last ${data.count} snaps 💔`;
                } else { alertBox.classList.add('hidden'); }
            } catch (e) { }
        }

        setInterval(loadLastSnap, 4000);
        setInterval(checkAttention, 5000);
        window.addEventListener('load', () => { loadLastSnap(); checkAttention(); });

    </script>

