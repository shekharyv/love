<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | LoveSync Premium ❤️</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <!-- --- PWA MANIFEST & OFFLINE REGISTRATION --- -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#ff007f">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').then(reg => {
                    console.log('✅ PWA: Service Worker Registered! Offline Mode Active. 🕵️‍♂️🛡️');
                }).catch(err => console.log('🛑 PWA: Registration Failed.', err));
            });
        }
    </script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        (function () {
            const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            if (theme === 'dark') document.documentElement.classList.add('dark');
        })();

        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        'brand-purple': '#4D128B', 'brand-pink': '#E11D48',
                        'neon-pink': '#FF007F', 'neon-purple': '#9D50BB',
                    }
                }
            }
        }


        function handleHeaderClick() {
            window.location.href = '/profile';
        }
    </script>
    <style>
        .heart {
            position: absolute;
            color: #FF1493;
            pointer-events: none;
            animation: rise 6s infinite ease-in;
            opacity: 0;
            z-index: 0;
        }

        @keyframes rise {
            0% {
                transform: translateY(100vh) scale(0.5);
                opacity: 0;
            }

            50% {
                opacity: 0.3;
            }

            100% {
                transform: translateY(-10vh) scale(1.2);
                opacity: 0;
            }
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 0, 0, 0.1);
            transition: background 0.5s, border 0.5s;
        }

        .dark .glass-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .camera-btn {
            background: radial-gradient(circle, #E11D48 0%, #9333EA 100%);
            box-shadow: 0 0 30px rgba(225, 29, 72, 0.4), 0 0 60px rgba(147, 51, 234, 0.2);
        }

        .camera-btn:active {
            transform: scale(0.9);
        }

        .pulse-glow {
            animation: pulse-glow 2s infinite ease-in-out;
        }

        @keyframes pulse-glow {

            0%,
            100% {
                box-shadow: 0 0 30px rgba(225, 29, 72, 0.4);
            }

            50% {
                box-shadow: 0 0 50px rgba(225, 29, 72, 0.7);
            }
        }

        .vibrate {
            animation: vibrate 0.1s linear 2;
        }

        @keyframes vibrate {
            0% {
                transform: translate(0, 0);
            }

            50% {
                transform: translate(2px, 2px);
            }

            100% {
                transform: translate(-2px, -2px);
            }
        }

        .loader-overlay {
            position: fixed;
            inset: 0;
            background: #0a0514;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s ease-out, visibility 0.5s;
        }

        .toast-notification {
            position: fixed;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            background: #E11D48;
            color: white;
            padding: 12px 24px;
            border-radius: 100px;
            font-weight: 800;
            font-size: 14px;
            box-shadow: 0 10px 40px rgba(225, 29, 72, 0.4);
            z-index: 60;
            display: none;
            animation: popUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes popUp {
            from {
                transform: translateX(-50%) translateY(50px);
                opacity: 0;
            }

            to {
                transform: translateX(-50%) translateY(0);
                opacity: 1;
            }
        }

        .reveal-card {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.6s ease-out;
        }

        .reveal-card.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- GAME ANIMATIONS --- */
        .winner-glow {
            animation: winner-pulse 1.5s infinite;
            border-color: #E11D48 !important;
            box-shadow: 0 0 40px rgba(225, 29, 72, 0.6) !important;
        }

        @keyframes winner-pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.02);
            }

            100% {
                transform: scale(1);
            }
        }

        .loser-shake {
            animation: shake 0.5s cubic-bezier(.36, .07, .19, .97) both;
            filter: grayscale(1) opacity(0.6);
            pointer-events: none;
        }

        @keyframes shake {

            10%,
            90% {
                transform: translate3d(-1px, 0, 0);
            }

            20%,
            80% {
                transform: translate3d(2px, 0, 0);
            }

            30%,
            50%,
            70% {
                transform: translate3d(-4px, 0, 0);
            }

            40%,
            60% {
                transform: translate3d(4px, 0, 0);
            }
        }

        .confetti {
            position: fixed;
            top: -10px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            animation: fall 3s linear forwards;
            pointer-events: none;
            z-index: 1000;
        }

        @keyframes fall {
            to {
                transform: translateY(100vh) rotate(360deg);
                opacity: 0;
            }
        }

        /* --- SYNC SUCCESS ANIMATION --- */
        .sync-success-overlay {
            position: fixed;
            inset: 0;
            background: #0a0514;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.5s ease;
        }

        .sync-success-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .heart-merge {
            position: relative;
            width: 200px;
            height: 200px;
        }

        .merging-heart {
            position: absolute;
            font-size: 80px;
            color: #E11D48;
            filter: drop-shadow(0 0 20px rgba(225, 29, 72, 0.5));
        }

        .heart-left { left: 0; animation: mergeLeft 2s infinite ease-in-out; }
        .heart-right { right: 0; animation: mergeRight 2s infinite ease-in-out; }

        @keyframes mergeLeft {
            0% { transform: translateX(0); opacity: 0.5; }
            50% { transform: translateX(40px); opacity: 1; }
            100% { transform: translateX(0); opacity: 0.5; }
        }
        @keyframes mergeRight {
            0% { transform: translateX(0); opacity: 0.5; }
            50% { transform: translateX(-40px); opacity: 1; }
            100% { transform: translateX(0); opacity: 0.5; }
        }

        .pulse-burst {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100px;
            height: 100px;
            background: rgba(225, 29, 72, 0.3);
            border-radius: 50%;
            z-index: -1;
            animation: pulseBurst 2s infinite;
        }

        @keyframes pulseBurst {
            0% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
            100% { transform: translate(-50%, -50%) scale(4); opacity: 0; }
        }
    </style>
</head>

<body
    class="bg-white text-gray-900 dark:bg-[#0a0514] dark:text-white transition-colors duration-500 overflow-x-hidden font-sans min-h-screen pb-40">

    <!-- Loading Overlay -->
    <div id="loader" class="loader-overlay">
        <div class="flex flex-col items-center">
            <div class="w-20 h-20 bg-btn-gradient rounded-3xl animate-bounce flex items-center justify-center p-4">
                <i class="fas fa-heart text-5xl text-white"></i>
            </div>
            <p class="mt-6 text-brand-pink font-black uppercase tracking-[0.3em] animate-pulse">Syncing Love...</p>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast-notification">Sent ❤️</div>

    <!-- Animated Heart Background -->
    <div id="heart-container" class="fixed inset-0 overflow-hidden pointer-events-none z-0"></div>

    <!-- Sticky Header -->
    <header class="sticky top-0 z-50 bg-[#0a0514]/80 backdrop-blur-xl border-b border-white/5 px-4 md:px-6 py-4 flex items-center justify-between">
        <div class="flex items-center space-x-3">
            <div class="relative group cursor-pointer" onclick="handleHeaderClick()">
                <div class="absolute -inset-1 bg-gradient-to-r from-brand-pink to-brand-purple rounded-full blur opacity-40 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"></div>
                <img id="partner-img" src="/images/partner-avatar.png" alt="Partner"
                    class="relative w-10 h-10 md:w-12 md:h-12 rounded-full border border-white/20 p-0.5 shadow-xl transition-transform group-hover:scale-110">
                <div id="status-indicator" class="absolute bottom-0 right-0 w-3 h-3 bg-gray-500 rounded-full border-2 border-[#0a0514]"></div>
            </div>
            <div class="flex flex-col">
                <span id="header-partner-name" class="text-xs md:text-sm font-black tracking-tight text-white/90"><%= user.partnerName || "No Partner Linked" %></span>
                <p id="partner-status" class="text-[8px] md:text-[10px] text-gray-500 font-bold uppercase tracking-widest opacity-60">Status</p>
            </div>
        </div>

        <div class="flex items-center space-x-2 md:space-x-4">
            <div class="flex items-center bg-white/5 border border-white/10 rounded-2xl px-3 py-1.5 md:px-4 md:py-2">
                <span class="text-lg mr-2">🔥</span>
                <div class="text-left border-l border-white/10 pl-2">
                    <span class="block text-[8px] text-gray-500 font-bold uppercase">Streak</span>
                    <span id="user-streak" class="text-xs font-black text-brand-pink"><%= user.streak || 0 %> Days</span>
                </div>
            </div>
            
            <div class="flex space-x-1 md:space-x-2">
                <button onclick="window.location.href='/discover'"
                    class="w-8 h-8 md:w-10 md:h-10 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center text-brand-pink hover:bg-brand-pink hover:text-white transition-all">
                    <i class="fas fa-fire text-xs md:text-sm"></i>
                </button>
                <button onclick="window.location.href='/find-partner'"
                    class="w-8 h-8 md:w-10 md:h-10 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center text-brand-pink hover:bg-brand-pink hover:text-white transition-all">
                    <i class="fas fa-user-plus text-xs md:text-sm"></i>
                </button>
            </div>
        </div>
    </header>

    <!-- Welcome Hero -->
    <div class="max-w-7xl mx-auto px-6 pt-10">
        <div class="relative overflow-hidden p-8 rounded-[2.5rem] bg-gradient-to-br from-brand-pink/10 to-transparent border border-white/5">
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-brand-pink/10 blur-[100px] rounded-full"></div>
            <div class="relative z-10 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
                <div>
                    <h1 class="text-4xl md:text-5xl font-black italic tracking-tighter">
                        <span id="welcome-text" class="text-gray-400">Good Evening</span>, 
                        <br class="md:hidden">
                        <span id="user-name" class="bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent"><%= user.name %></span>
                    </h1>
                    <div class="flex items-center space-x-3 mt-4">
                        <div class="px-3 py-1 bg-white/5 border border-white/10 rounded-full flex items-center space-x-2">
                            <span class="text-brand-pink">❤️</span>
                            <span class="text-[10px] font-black uppercase tracking-widest text-gray-400" id="current-vibe"><%= user.partnerId ? "Syncing Live" : "Vibing Offline" %></span>
                        </div>
                    </div>
                </div>
                
                <div class="flex -space-x-3 overflow-hidden group cursor-pointer" onclick="window.location.href='/profile'">
                    <div class="w-16 h-16 rounded-full border-4 border-[#0a0514] bg-white/10 flex items-center justify-center text-2xl shadow-2xl z-20">👤</div>
                    <div class="w-16 h-16 rounded-full border-4 border-[#0a0514] bg-brand-pink flex items-center justify-center text-2xl shadow-2xl z-10 relative">
                        <img src="/images/partner-avatar.png" class="absolute inset-0 w-full h-full object-cover rounded-full opacity-60">
                        <span class="relative z-10">❤️</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content Grid -->
    <main class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 relative z-10">

        <!-- Mood Check Widget -->
        <div id="mood-widget" class="glass-card p-6 reveal-card active transition-all duration-500">
            <h4
                class="font-black text-[10px] uppercase tracking-widest text-gray-500 mb-6 flex items-center justify-between">
                <span>Mood Sync ❤️</span>
                <span id="mood-match-badge"
                    class="hidden px-2 py-0.5 bg-brand-pink/20 text-brand-pink rounded-full text-[8px] animate-pulse">Sync
                    Perfect!</span>
            </h4>

            <div class="flex justify-between items-center mb-8 px-4">
                <div class="text-center group">
                    <p
                        class="text-[9px] font-black uppercase text-gray-500 mb-2 group-hover:text-white transition-colors">
                        You</p>
                    <div id="user-mood-emoji"
                        class="text-4xl transition-all duration-500 <%= user.mood && user.mood !== " ❓" ? ""
                        : "grayscale" %>"><%= user.mood || "❓" %>
                    </div>
                </div>
                <div class="flex flex-col items-center">
                    <div class="w-1 h-12 bg-white/5 rounded-full relative overflow-hidden">
                        <div id="sync-progress" class="absolute inset-0 bg-brand-pink h-0 transition-all duration-1000">
                        </div>
                    </div>
                </div>
                <div class="text-center group">
                    <p
                        class="text-[9px] font-black uppercase text-gray-500 mb-2 group-hover:text-white transition-colors">
                        <span id="partnerLabel">Partner</span>
                    </p>
                    <div id="partner-mood-emoji" class="text-4xl filter grayscale transition-all duration-500">❓</div>
                </div>
            </div>

            <p class="text-[11px] font-bold text-gray-400 mb-4 text-center" id="mood-sync-status">Set your mood to sync
                with Partner...</p>

            <div class="flex mt-4 justify-between items-center bg-black/40 p-1.5 rounded-2xl">
                <button onclick="setMood('😊')"
                    class="mood-btn w-10 h-10 flex items-center justify-center text-2xl hover:bg-white/10 rounded-xl transition-all">😊</button>
                <button onclick="setMood('😍')"
                    class="mood-btn w-10 h-10 flex items-center justify-center text-2xl hover:bg-white/10 rounded-xl transition-all">😍</button>
                <button onclick="setMood('😔')"
                    class="mood-btn w-10 h-10 flex items-center justify-center text-2xl hover:bg-white/10 rounded-xl transition-all">😔</button>
                <button onclick="setMood('😡')"
                    class="mood-btn w-10 h-10 flex items-center justify-center text-2xl hover:bg-white/10 rounded-xl transition-all">😡</button>
                <button onclick="setMood('😴')"
                    class="mood-btn w-10 h-10 flex items-center justify-center text-2xl hover:bg-white/10 rounded-xl transition-all">😴</button>
            </div>
        </div>

        <!-- Watch Together Game Card -->
        <div id="watch-home-card"
            class="glass-card p-6 reveal-card active border-indigo-500/20 bg-gradient-to-br from-indigo-500/10 to-transparent group overflow-hidden relative">
            <div
                class="absolute -right-8 -top-8 w-24 h-24 bg-indigo-500/10 blur-3xl group-hover:bg-indigo-500/20 transition-all">
            </div>

            <div class="flex items-center justify-between mb-6">
                <h4 class="font-black text-[10px] uppercase tracking-[0.2em] text-indigo-400">Cinema Mode 🎬</h4>
                <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></div>
            </div>

            <div class="text-center mb-8">
                <p class="text-xl font-black italic mb-2">Watch Together <span class="text-indigo-400">🍿</span></p>
                <p class="text-[10px] text-gray-500 font-bold tracking-widest uppercase">Sync your movies</p>
            </div>

            <div
                class="bg-black/20 p-5 rounded-2xl mb-6 flex flex-col items-center justify-center text-center border border-white/5 min-h-[100px]">
                <p class="text-sm font-bold italic text-indigo-200">"Watch your favorite moments together ❤️"
                </p>
            </div>

            <button onclick="window.location.href='/watch'"
                class="w-full py-4 bg-indigo-600/20 border border-indigo-500/40 rounded-2xl font-black uppercase text-[10px] tracking-widest text-indigo-400 hover:bg-indigo-600 hover:text-white transition-all shadow-lg active:scale-95">
                Start Watching 🎬
            </button>
        </div>

        <!-- Tic Tac Toe Game Card -->
        <div id="ttt-home-card"
            class="glass-card p-6 reveal-card active border-cyan-500/20 bg-gradient-to-br from-cyan-500/10 to-transparent group overflow-hidden relative">
            <div
                class="absolute -right-8 -top-8 w-24 h-24 bg-cyan-500/10 blur-3xl group-hover:bg-cyan-500/20 transition-all">
            </div>

            <div class="flex items-center justify-between mb-6">
                <h4 class="font-black text-[10px] uppercase tracking-[0.2em] text-cyan-400">Action Game 🎮</h4>
                <div class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-pulse"></div>
            </div>

            <div class="text-center mb-8">
                <p class="text-xl font-black italic mb-2">Tic Tac Toe <span class="text-cyan-400">⚔️</span></p>
                <p class="text-[10px] text-gray-500 font-bold tracking-widest uppercase">Challenge your partner</p>
            </div>

            <div id="ttt-card-body"
                class="bg-black/20 p-5 rounded-2xl mb-6 flex flex-col items-center justify-center text-center border border-white/5 min-h-[100px]">
                <p id="ttt-card-status" class="text-sm font-bold italic text-cyan-200">"Wanna see who is smarter? 😏"
                </p>
            </div>

            <button onclick="startTTT()"
                class="w-full py-4 bg-cyan-600/20 border border-cyan-500/40 rounded-2xl font-black uppercase text-[10px] tracking-widest text-cyan-400 hover:bg-cyan-600 hover:text-white transition-all shadow-lg active:scale-95">
                Play Now 🎮
            </button>
        </div>

        <!-- Truth or Dare Game Card -->
        <div
            class="glass-card p-6 reveal-card active border-purple-500/20 bg-gradient-to-br from-purple-500/10 to-transparent group overflow-hidden relative">
            <div
                class="absolute -right-8 -top-8 w-24 h-24 bg-purple-500/10 blur-3xl group-hover:bg-purple-500/20 transition-all">
            </div>

            <div class="flex items-center justify-between mb-6">
                <h4 class="font-black text-[10px] uppercase tracking-[0.2em] text-purple-400">Relationship Game 🎭</h4>
                <div class="flex space-x-2">
                    <button onclick="toggleManualMode()" id="manual-toggle"
                        class="text-[8px] font-black uppercase text-gray-500 border border-white/5 px-2 py-0.5 rounded-full hover:bg-white/10 transition-all">Manual:
                        OFF</button>
                    <div class="w-1.5 h-1.5 rounded-full bg-purple-500 animate-pulse"></div>
                </div>
            </div>

            <div class="text-center mb-8">
                <p class="text-xl font-black italic mb-2">Truth or Dare <span class="text-purple-400">🔥</span></p>
                <p class="text-[10px] text-gray-500 font-bold tracking-widest uppercase">Challenge your partner</p>
            </div>

            <div id="game-display"
                class="bg-black/20 p-5 rounded-2xl mb-6 min-h-[120px] flex flex-col items-center justify-center text-center border border-white/5 relative group-hover:border-purple-500/30 transition-all">
                <p id="game-prompt" class="text-sm font-bold italic text-purple-200">"Tap to generate a spicy AI
                    challenge..."</p>

                <textarea id="manual-input" placeholder="Type your own challenge here... ✍️"
                    class="hidden w-full bg-transparent border-none text-center text-sm font-bold italic text-purple-200 focus:ring-0 placeholder:text-gray-600 resize-none h-16"></textarea>
            </div>

            <div class="mb-5">
                <p class="text-[9px] font-black uppercase text-gray-500 tracking-[0.3em] mb-4 text-center">Set Vibe Level ✨</p>
                <div class="grid grid-cols-4 gap-1.5 bg-white/5 p-1 rounded-[1.8rem] border border-white/5">
                    <button onclick="setGameLevel(1, this)" class="game-lvl-btn py-2 rounded-2xl text-[7px] font-black uppercase tracking-widest text-gray-500 bg-transparent transition-all border border-transparent shadow-none" data-level="1">
                        Normal 💖
                    </button>
                    <button onclick="setGameLevel(2, this)" class="game-lvl-btn py-2 rounded-2xl text-[7px] font-black uppercase tracking-widest text-[#9333EA] bg-transparent transition-all border border-transparent shadow-none" data-level="2">
                        Medium 🔥
                    </button>
                    <button onclick="setGameLevel(3, this)" class="game-lvl-btn py-2 rounded-2xl text-[7px] font-black uppercase tracking-widest text-blue-400 bg-transparent transition-all border border-transparent shadow-none" data-level="3">
                        Deep ❤️
                    </button>
                    <button onclick="setGameLevel(4, this)" class="game-lvl-btn py-2 rounded-[1.2rem] text-[7px] font-black uppercase tracking-widest text-white bg-gradient-to-r from-brand-pink to-purple-600 transition-all border border-white/10 shadow-[0_0_20px_rgba(225,29,72,0.3)]" data-level="4">
                        Naughty 😏
                    </button>
                </div>
            </div>

            <div id="ai-controls" class="grid grid-cols-2 gap-3">
                <button onclick="generateGame('truth')"
                    class="py-4 bg-purple-600/20 border border-purple-500/30 rounded-2xl font-black uppercase text-[10px] tracking-widest hover:bg-purple-600 hover:text-white transition-all shadow-lg active:scale-95">
                    Truth 💎
                </button>
                <button onclick="generateGame('dare')"
                    class="py-4 bg-pink-600/20 border border-pink-500/30 rounded-2xl font-black uppercase text-[10px] tracking-widest hover:bg-pink-600 hover:text-white transition-all shadow-lg active:scale-95">
                    Dare 🔥
                </button>
            </div>

            <button onclick="sendGameChallenge()" id="game-send-btn"
                class="w-full mt-4 py-3 bg-white text-black rounded-xl font-black uppercase text-[9px] tracking-[0.2em] opacity-0 pointer-events-none transition-all hover:scale-105 active:scale-95">
                Send Challenge 📩
            </button>
        </div>

        <!-- Daily Love Quiz Widget -->
        <div
