<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Find Partner | LoveSync ❤️</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <script src="/socket.io/socket.io.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        'brand-purple': '#4D128B',
                        'brand-pink': '#E11D48',
                        'neon-pink': '#FF007F',
                        'neon-purple': '#9D50BB',
                    }
                }
            }
        }
    </script>
    <style>
        .heart {
            position: absolute;
            color: #FF1493;
            pointer-events: none;
            animation: rise 6s infinite ease-in;
            opacity: 0;
            z-index: 0;
        }

        @keyframes rise {
            0% {
                transform: translateY(100vh) scale(0.5);
                opacity: 0;
            }

            100% {
                transform: translateY(-10vh) scale(1.2);
                opacity: 0;
            }
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1.5rem;
        }

        .search-bar:focus {
            box-shadow: 0 0 20px rgba(225, 29, 72, 0.3);
            border-color: rgba(225, 29, 72, 0.5);
        }

        #heart-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.8);
            display: none;
            items-center;
            justify-content: center;
            z-index: 1000;
        }

        .pop-heart {
            animation: heartPop 1s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        @keyframes heartPop {
            0% {
                transform: scale(0);
                opacity: 0;
            }

            50% {
                transform: scale(1.5);
                opacity: 1;
            }

            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        .toast {
            position: fixed;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            background: #E11D48;
            color: white;
            padding: 12px 24px;
            border-radius: 100px;
            font-weight: 800;
            font-size: 14px;
            box-shadow: 0 10px 40px rgba(225, 29, 72, 0.4);
            z-index: 100;
            display: none;
            animation: popUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes popUp {
            from {
                transform: translateX(-50%) translateY(50px);
                opacity: 0;
            }

            to {
                transform: translateX(-50%) translateY(0);
                opacity: 1;
            }
        }
    </style>
</head>

<body class="bg-[#0a0514] text-white overflow-x-hidden font-sans min-h-screen">

    <div id="toast" class="toast">Request Sent ❤️</div>
    <div id="heart-container" class="fixed inset-0 pointer-events-none z-0"></div>

    <!-- Heart Animation Overlay -->
    <div id="heart-overlay" class="backdrop-blur-xl">
        <div class="text-center space-y-6 pop-heart">
            <i class="fas fa-heart text-9xl text-brand-pink drop-shadow-[0_0_40px_rgba(225,29,72,0.6)]"></i>
            <h2 class="text-4xl font-black italic tracking-tighter">Connected Successfully! 💑</h2>
            <p class="text-gray-400 font-bold uppercase tracking-widest">Your journey begins now...</p>
            <button onclick="window.location.href='/home'"
                class="mt-8 bg-white text-black px-10 py-4 rounded-full font-black uppercase text-xs tracking-widest">Go
                to Home</button>
        </div>
    </div>

    <!-- Header -->
    <header class="sticky top-0 z-50 bg-[#0a0514]/60 backdrop-blur-2xl border-b border-white/5 px-6 py-6 space-y-6">
        <div class="flex items-center justify-between">
            <a href="/home"
                class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center border border-white/10">
                <i class="fas fa-chevron-left text-sm"></i>
            </a>
            <div class="text-center flex-1">
                <h1 class="font-black text-xl tracking-tight">Find Partner 💑</h1>
                <p class="text-[10px] text-gray-500 font-black uppercase tracking-widest">Connect with something special
                    ❤️</p>
            </div>
            <button class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center border border-white/10">
                <i class="fas fa-qrcode text-sm text-brand-pink"></i>
            </button>
        </div>

        <div class="relative group">
            <i
                class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-gray-500 group-focus-within:text-brand-pink transition-colors"></i>
            <input type="text" id="user-search" placeholder="Search by username or email..."
                class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-14 pr-6 focus:outline-none search-bar transition-all font-bold text-sm">
        </div>
    </header>

    <main class="max-w-xl mx-auto px-6 py-10 space-y-12 pb-40 relative z-10">

        <!-- Search Results (Hidden by default) -->
        <section id="search-section" class="hidden space-y-6 animate-pulse">
            <h3 class="font-black text-sm uppercase tracking-widest text-brand-pink flex items-center">
                <i class="fas fa-cloud-moon mr-2"></i> Results for your soulmate
            </h3>
            <div id="search-results" class="space-y-4">
                <!-- Result card dynamic -->
            </div>
        </section>

        <!-- Connected Partner Status (Example) -->
        <div class="glass-card p-6 bg-gradient-to-r from-brand-pink/10 to-brand-purple/10 border-brand-pink/20">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-white/10 rounded-full border border-brand-pink p-0.5">
                        <img src="/images/partner-avatar.png" class="w-full h-full rounded-full">
                    </div>
                    <div>
                        <p class="text-xs font-black uppercase tracking-widest text-brand-pink">Currently Connected</p>
                        <p class="font-bold">Partner ❤️</p>
                    </div>
                </div>
                <button onclick="window.location.href='/profile'"
                    class="text-[9px] font-black uppercase bg-white/5 border border-white/10 px-4 py-2 rounded-xl">View
                    Profile</button>
            </div>
        </div>

        <!-- Incoming Requests -->
        <section class="space-y-6">
            <h3 class="font-black text-sm uppercase tracking-widest text-gray-500 flex items-center">
                <i class="fas fa-envelope-open-text mr-2 text-brand-pink"></i> Incoming Requests 💌
            </h3>
            <div id="incoming-requests" class="space-y-4">
                <div
                    class="glass-card p-4 flex items-center justify-between group hover:border-brand-pink/30 transition-all">
                    <div class="flex items-center space-x-4">
                        <div
                            class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-xl overflow-hidden">
                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Priya" alt="Priya">
                        </div>
                        <div>
                            <p class="font-black">Priya ✨</p>
                            <p class="text-[10px] text-gray-500 font-black uppercase tracking-widest">@priya_soul</p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-2">
                        <button onclick="acceptRequest(this, 'Priya')"
                            class="w-10 h-10 bg-brand-pink rounded-xl flex items-center justify-center shadow-lg shadow-brand-pink/20"><i
                                class="fas fa-check"></i></button>
                        <button
                            class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center border border-white/10"><i
                                class="fas fa-times text-gray-500"></i></button>
                    </div>
                </div>
            </div>
        </section>

        <!-- Suggested Users -->
        <section class="space-y-6">
            <h3 class="font-black text-sm uppercase tracking-widest text-gray-500 flex items-center">
                <i class="fas fa-fire-alt mr-2 text-orange-500"></i> Suggested for You 🔥
            </h3>
            <div id="suggestions" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Suggestion cards -->
                <div class="glass-card p-6 text-center space-y-4 hover:scale-105 transition-all">
                    <div class="w-20 h-20 bg-white/5 rounded-full mx-auto relative group">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Amit"
                            class="w-full h-full rounded-full">
                        <div
                            class="absolute inset-0 bg-brand-pink/20 rounded-full opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center">
                            <i class="fas fa-heart text-white"></i>
                        </div>
                    </div>
                    <div>
                        <p class="font-black">Amit Kumar</p>
                        <p class="text-[9px] text-gray-500 font-black uppercase">@amit_dev</p>
                    </div>
                    <button onclick="sendRequest(this)"
                        class="w-full py-2 bg-brand-pin/10 border border-brand-pink/30 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-brand-pink hover:text-white transition-all">Add
                        ❤️</button>
                </div>

                <div class="glass-card p-6 text-center space-y-4 hover:scale-105 transition-all">
                    <div class="w-20 h-20 bg-white/5 rounded-full mx-auto relative group">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Sneha"
                            class="w-full h-full rounded-full">
                        <div
                            class="absolute inset-0 bg-brand-pink/20 rounded-full opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center">
                            <i class="fas fa-heart text-white"></i>
                        </div>
                    </div>
                    <div>
                        <p class="font-black">Sneha Sharma</p>
                        <p class="text-[9px] text-gray-500 font-black uppercase">@sneha_hearts</p>
                    </div>
                    <button onclick="sendRequest(this)"
                        class="w-full py-2 bg-brand-pink/10 border border-brand-pink/30 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-brand-pink hover:text-white transition-all">Add
                        ❤️</button>
                </div>
            </div>
        </section>

        <!-- Invite System -->
        <section class="glass-card p-10 text-center space-y-6 relative overflow-hidden">
            <div class="absolute -right-10 -bottom-10 w-32 h-32 bg-brand-pink/5 blur-3xl"></div>
            <div
                class="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center mx-auto text-brand-pink text-2xl">
                <i class="fas fa-share-alt"></i>
            </div>
            <div>
                <h3 class="text-xl font-black mb-2">Can't find them? 🏹</h3>
                <p class="text-xs text-gray-500 font-bold max-w-[200px] mx-auto">Invite your partner directly with a
                    secure link.</p>
            </div>
            <div class="relative">
                <input type="text" readonly value="lovesync.app/invite/9x2k-8" id="invite-link"
                    class="w-full bg-black/40 border border-white/10 rounded-2xl py-4 px-6 text-center text-xs font-bold text-gray-400">
                <button onclick="copyInvite()"
                    class="w-full mt-4 bg-brand-pink py-4 rounded-xl font-black text-xs uppercase tracking-widest shadow-xl shadow-brand-pink/20 active:scale-95 transition-all">
                    Copy Link 📋
                </button>
            </div>
        </section>

    </main>

    <!-- Bottom Nav -->
    <nav class="fixed bottom-6 left-6 right-6 z-50">
        <div
            class="max-w-md mx-auto bg-black/40 backdrop-blur-3xl border border-white/10 rounded-full p-2 flex items-center justify-between shadow-2xl">
            <a href="/home"
                class="flex-1 flex flex-col items-center justify-center p-2 text-gray-500 hover:text-white transition-all"><i
                    class="fas fa-home text-lg mb-1"></i><span
                    class="text-[8px] font-black uppercase tracking-tighter">Home</span></a>
            <a href="/chat"
                class="flex-1 flex flex-col items-center justify-center p-2 text-gray-500 hover:text-white transition-all"><i
                    class="fas fa-comment-dots text-lg mb-1"></i><span
                    class="text-[8px] font-black uppercase tracking-tighter">Chat</span></a>
            <div class="relative -top-3"><button
                    class="w-16 h-16 rounded-full border-4 border-[#0a0514] flex items-center justify-center shadow-2xl bg-brand-pink"><i
                        class="fas fa-camera text-xl text-white"></i></button></div>
            <a href="/insights"
                class="flex-1 flex flex-col items-center justify-center p-2 text-gray-500 hover:text-white transition-all"><i
                    class="fas fa-chart-pie text-lg mb-1"></i><span
                    class="text-[8px] font-black uppercase tracking-tighter">Insights</span></a>
            <a href="/profile"
                class="flex-1 flex flex-col items-center justify-center p-2 text-gray-500 hover:text-brand-pink transition-all">
                <div class="w-5 h-5 rounded-full overflow-hidden border border-white/20 mb-1"><img
                        src="/images/partner-avatar.png"></div><span
                    class="text-[8px] font-black uppercase tracking-tighter">Account</span>
            </a>
        </div>
    </nav>

    <script>
        // Floating Hearts Gen
        const container = document.getElementById('heart-container');
        function createHeart() {
            const heart = document.createElement('div'); heart.classList.add('heart');
            heart.innerHTML = '<i class="fas fa-heart"></i>'; heart.style.left = Math.random() * 100 + 'vw';
            heart.style.fontSize = Math.random() * 10 + 10 + 'px'; heart.style.animationDuration = Math.random() * 5 + 5 + 's';
            container.appendChild(heart);
            setTimeout(() => heart.remove(), 10000);
        }
        setInterval(createHeart, 1000);

        // Search Logic
        const searchInput = document.getElementById('user-search');
        const searchSection = document.getElementById('search-section');
        const searchResults = document.getElementById('search-results');

        const mockUsers = [
            { name: "Ananya", user: "@ananya_love", bio: "Looking for real connection.", img: "7" },
            { name: "Rahul", user: "@rahul_hearts", bio: "Music and Love.", img: "3" },
            { name: "Ishaan", user: "@ishaan_sky", bio: "The sky is the limit.", img: "11" }
        ];

        searchInput.addEventListener('input', (e) => {
            const val = e.target.value.toLowerCase();
            if (val.length > 2) {
                searchSection.classList.remove('hidden');
                const filtered = mockUsers.filter(u => u.name.toLowerCase().includes(val) || u.user.toLowerCase().includes(val));
                renderResults(filtered);
            } else {
                searchSection.classList.add('hidden');
            }
        });

        function renderResults(users) {
            if (users.length === 0) {
                searchResults.innerHTML = '<div class="text-center py-10 opacity-40"><i class="fas fa-ghost text-4xl mb-4"></i><p class="text-xs font-black uppercase">No soulmate found</p></div>';
                return;
            }
            searchResults.innerHTML = users.map(u => `
                <div class="glass-card p-5 flex items-center justify-between group hover:bg-white/5 transition-all">
                    <div class="flex items-center space-x-4">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=${u.img}" class="w-12 h-12 rounded-xl bg-white/10">
                        <div>
                            <p class="font-black text-sm">${u.name}</p>
                            <p class="text-[9px] text-gray-500 font-black uppercase tracking-widest">${u.user}</p>
                        </div>
                    </div>
                    <button onclick="sendRequest(this)" class="bg-brand-pink text-white px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-brand-pink/20 active:scale-95 transition-all">Add ❤️</button>
                </div>
            `).join('');
        }

        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.innerText = msg;
            toast.style.display = 'block';
            setTimeout(() => toast.style.display = 'none', 3000);
        }

        function sendRequest(btn) {
            btn.innerHTML = '<i class="fas fa-spinner animate-spin"></i>';
            btn.disabled = true;
            setTimeout(() => {
                btn.innerHTML = 'Pending ⏳';
                btn.className = "bg-white/5 border border-white/10 px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest text-gray-500";
                showToast("Request Sent ❤️");
            }, 1000);
        }

        function acceptRequest(btn, name) {
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner animate-spin"></i>';
            setTimeout(() => {
                const overlay = document.getElementById('heart-overlay');
                overlay.style.display = 'flex';
                navigator.vibrate?.([100, 50, 100, 50, 300]);
            }, 1000);
        }

        function copyInvite() {
            const link = document.getElementById('invite-link');
            link.select();
            document.execCommand('copy');
            showToast("Invite Link Copied! 📋");
        }
    </script>
</body>

</html>