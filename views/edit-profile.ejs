<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile | LoveSync Premium ❤️</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        'brand-purple': '#4D128B',
                        'brand-pink': '#E11D48',
                        'neon-pink': '#FF007F',
                        'neon-purple': '#9D50BB',
                    }
                }
            }
        }
    </script>
    <style>
        .heart {
            position: absolute;
            color: #FF1493;
            pointer-events: none;
            animation: rise 6s infinite ease-in;
            opacity: 0;
            z-index: 0;
        }

        @keyframes rise {
            0% {
                transform: translateY(100vh) scale(0.5);
                opacity: 0;
            }

            100% {
                transform: translateY(-10vh) scale(1.2);
                opacity: 0;
            }
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1.5rem;
        }

        .input-glass {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .input-glass:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: #E11D48;
            box-shadow: 0 0 15px rgba(225, 29, 72, 0.3);
            outline: none;
        }

        .toggle-switch {
            width: 44px;
            height: 22px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 100px;
            position: relative;
            cursor: pointer;
            transition: 0.3s;
        }

        .toggle-switch::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 16px;
            height: 16px;
            background: white;
            border-radius: 50%;
            transition: 0.3s;
        }

        .toggle-active {
            background: #E11D48 !important;
        }

        .toggle-active::after {
            left: 25px !important;
        }

        .toast {
            position: fixed;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            background: #0ea5e9;
            color: white;
            padding: 12px 24px;
            border-radius: 100px;
            font-weight: 800;
            font-size: 14px;
            box-shadow: 0 10px 40px rgba(14, 165, 233, 0.4);
            z-index: 100;
            display: none;
            animation: popUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes popUp {
            from {
                transform: translateX(-50%) translateY(50px);
                opacity: 0;
            }

            to {
                transform: translateX(-50%) translateY(0);
                opacity: 1;
            }
        }

        .glow-border {
            position: relative;
        }

        .glow-border::after {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 9999px;
            background: linear-gradient(45deg, #E11D48, #9333EA, #E11D48);
            background-size: 400% 400%;
            animation: glowRotate 5s linear infinite;
            z-index: -1;
            filter: blur(10px);
            opacity: 0.6;
        }

        @keyframes glowRotate {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }
    </style>
</head>

<body class="bg-[#0a0514] text-white overflow-x-hidden font-sans min-h-screen">

    <div id="toast" class="toast">Profile Updated! ❤️</div>
    <div id="heart-container" class="fixed inset-0 pointer-events-none z-0"></div>

    <!-- Sticky Header -->
    <header
        class="sticky top-0 z-50 bg-[#0a0514]/60 backdrop-blur-2xl border-b border-white/5 px-6 py-6 flex items-center justify-between">
        <a href="/profile"
            class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center border border-white/10 hover:bg-white/10 transition-all">
            <i class="fas fa-chevron-left"></i>
        </a>
        <h1 class="font-black text-lg tracking-tight">Edit Profile ✏️</h1>
        <button onclick="saveProfile()"
            class="bg-btn-gradient px-6 py-2 rounded-full font-black text-xs uppercase tracking-widest hover:shadow-[0_0_20px_rgba(225,29,72,0.5)] transition-all">
            Save
        </button>
    </header>

    <main class="max-w-xl mx-auto px-6 py-10 space-y-12 relative z-10 pb-32">

        <!-- Profile Image Section -->
        <section class="flex flex-col items-center">
            <div class="relative group cursor-pointer" onclick="document.getElementById('file-input').click()">
                <div
                    class="w-32 h-32 rounded-full border-4 border-white/10 overflow-hidden glow-border relative bg-[#0a0514]">
                    <img id="profile-preview" src="/images/partner-avatar.png"
                        class="w-full h-full object-cover group-hover:scale-110 transition-all duration-500">
                    <div
                        class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all">
                        <i class="fas fa-camera text-2xl text-white"></i>
                    </div>
                </div>
            </div>
            <input type="file" id="file-input" class="hidden" accept="image/*" onchange="previewImage(event)">
            <div class="mt-6 flex space-x-4">
                <button onclick="document.getElementById('file-input').click()"
                    class="text-[10px] font-black uppercase text-brand-pink tracking-widest hover:underline">Upload
                    New</button>
                <button onclick="removeImage()"
                    class="text-[10px] font-black uppercase text-gray-500 tracking-widest hover:underline">Remove</button>
            </div>
        </section>

        <!-- Basic Info Form -->
        <section class="space-y-6">
            <h3
                class="font-black text-sm uppercase tracking-[0.2em] text-gray-500 border-l-4 border-brand-pink pl-4 mb-8">
                Basic Info</h3>

            <div class="space-y-4">
                <div class="group">
                    <label class="block text-[10px] font-black uppercase text-gray-500 mb-2 ml-4">Full Name</label>
                    <input type="text" value="Shekhar Kumar"
                        class="input-glass w-full px-6 py-4 rounded-2xl font-bold text-sm">
                </div>
                <div class="group">
                    <label class="block text-[10px] font-black uppercase text-gray-500 mb-2 ml-4">Username</label>
                    <input type="text" value="@shekhar_lovesync"
                        class="input-glass w-full px-6 py-4 rounded-2xl font-bold text-sm">
                </div>
                <div class="group">
                    <label class="block text-[10px] font-black uppercase text-gray-500 mb-2 ml-4">Short Bio</label>
                    <textarea rows="3"
                        class="input-glass w-full px-6 py-4 rounded-3xl font-medium text-sm no-scrollbar">Loving every second with my partner ❤️. Living for the little moments!</textarea>
                </div>
                <div class="group">
                    <label class="block text-[10px] font-black uppercase text-gray-500 mb-2 ml-4">Gender</label>
                    <div class="relative">
                        <select
                            class="input-glass w-full px-6 py-4 rounded-2xl font-bold text-sm appearance-none cursor-pointer">
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                        <i
                            class="fas fa-chevron-down absolute right-6 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                    </div>
                </div>
            </div>
        </section>

        <!-- Contact Info -->
        <section class="space-y-6 pt-6">
            <h3
                class="font-black text-sm uppercase tracking-[0.2em] text-gray-500 border-l-4 border-purple-500 pl-4 mb-8">
                Contact Info</h3>
            <div class="space-y-4">
                <div class="group relative">
                    <label class="block text-[10px] font-black uppercase text-gray-500 mb-2 ml-4">Email Address</label>
                    <div class="relative">
                        <input type="email" value="shekhar@lovesync.app"
                            class="input-glass w-full px-6 py-4 rounded-2xl font-bold text-sm">
                        <span
                            class="absolute right-6 top-1/2 -translate-y-1/2 flex items-center space-x-1 text-[10px] font-black text-green-400 uppercase">
                            <i class="fas fa-check-circle"></i> <span>Verified</span>
                        </span>
                    </div>
                </div>
                <div class="group">
                    <label class="block text-[10px] font-black uppercase text-gray-500 mb-2 ml-4">Phone Number</label>
                    <input type="tel" value="+91 98765 43210"
                        class="input-glass w-full px-6 py-4 rounded-2xl font-bold text-sm">
                </div>
            </div>
        </section>

        <!-- Relationship Info -->
        <section class="space-y-6 pt-6">
            <h3
                class="font-black text-sm uppercase tracking-[0.2em] text-gray-500 border-l-4 border-cyan-500 pl-4 mb-8">
                Relationship Info 💑</h3>
            <div class="space-y-4">
                <div class="group">
                    <label class="block text-[10px] font-black uppercase text-gray-500 mb-2 ml-4">Partner Name</label>
                    <input type="text" value="Partner" class="input-glass w-full px-6 py-4 rounded-2xl font-bold text-sm">
                </div>
                <div class="group">
                    <label class="block text-[10px] font-black uppercase text-gray-500 mb-2 ml-4">Anniversary Date
                        📅</label>
                    <input type="date" value="2026-01-01"
                        class="input-glass w-full px-6 py-4 rounded-2xl font-bold text-sm text-gray-400">
                </div>
                <div class="group">
                    <label class="block text-[10px] font-black uppercase text-gray-500 mb-2 ml-4">Relationship
                        Status</label>
                    <div class="relative">
                        <select
                            class="input-glass w-full px-6 py-4 rounded-2xl font-bold text-sm appearance-none cursor-pointer">
                            <option selected>Dating</option>
                            <option>Long Distance</option>
                            <option>Married</option>
                            <option>Engaged</option>
                        </select>
                        <i
                            class="fas fa-chevron-down absolute right-6 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                    </div>
                </div>
            </div>
        </section>

        <!-- Preferences -->
        <section class="glass-card overflow-hidden">
            <div class="p-8 border-b border-white/5">
                <h4 class="font-black text-xs uppercase tracking-widest text-gray-400">Preferences & Settings</h4>
            </div>
            <div class="divide-y divide-white/5">
                <div class="p-6 flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <i class="fas fa-bell text-yellow-400"></i>
                        <span class="text-sm font-bold">Notifications 🔔</span>
                    </div>
                    <div class="toggle-switch toggle-active" onclick="this.classList.toggle('toggle-active')"></div>
                </div>
                <div class="p-6 flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <i class="fas fa-moon text-purple-400"></i>
                        <span class="text-sm font-bold">Dark Mode 🌙</span>
                    </div>
                    <div class="toggle-switch toggle-active" onclick="this.classList.toggle('toggle-active')"></div>
                </div>
                <div class="p-6 flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <i class="fas fa-heart text-brand-pink"></i>
                        <span class="text-sm font-bold">Love Reminders ❤️</span>
                    </div>
                    <div class="toggle-switch toggle-active" onclick="this.classList.toggle('toggle-active')"></div>
                </div>
            </div>
        </section>

        <!-- Privacy Settings -->
        <section class="glass-card overflow-hidden">
            <div class="p-8 border-b border-white/5">
                <h4 class="font-black text-xs uppercase tracking-widest text-gray-400">Privacy Settings 🔒</h4>
            </div>
            <div class="divide-y divide-white/5">
                <div class="p-6 flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <i class="fas fa-eye-slash text-cyan-400"></i>
                        <span class="text-sm font-bold">Private Account</span>
                    </div>
                    <div class="toggle-switch" onclick="this.classList.toggle('toggle-active')"></div>
                </div>
                <div class="p-6 flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <i class="fas fa-star text-brand-pink"></i>
                        <span class="text-sm font-bold">Show Love Score</span>
                    </div>
                    <div class="toggle-switch toggle-active" onclick="this.classList.toggle('toggle-active')"></div>
                </div>
            </div>
        </section>

        <!-- Main Actions -->
        <section class="flex flex-col space-y-4 items-center !mt-16">
            <button id="save-btn" onclick="saveProfile()"
                class="w-full bg-btn-gradient py-5 rounded-[2rem] font-black text-white text-sm uppercase tracking-[0.2em] shadow-[0_20px_50px_rgba(225,29,72,0.4)] hover:shadow-[0_20px_60px_rgba(225,29,72,0.6)] transform active:scale-95 transition-all flex items-center justify-center space-x-3">
                <span id="btn-text">Save Changes ❤️</span>
                <i id="btn-loader" class="fas fa-spinner animate-spin hidden"></i>
            </button>
            <a href="/profile"
                class="text-xs font-black uppercase text-gray-600 tracking-widest hover:text-white transition-all pt-2">Discard
                Changes</a>
        </section>

    </main>

    <script>
        // Floating Hearts Gen
        const container = document.getElementById('heart-container');
        function createHeart() {
            const heart = document.createElement('div'); heart.classList.add('heart');
            heart.innerHTML = '<i class="fas fa-heart"></i>';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.fontSize = Math.random() * 10 + 10 + 'px';
            heart.style.animationDuration = Math.random() * 5 + 5 + 's';
            heart.style.animationDelay = -Math.random() * 10 + 's';
            container.appendChild(heart);
            setTimeout(() => heart.remove(), 10000);
        }
        setInterval(createHeart, 1000);

        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function () {
                const output = document.getElementById('profile-preview');
                output.src = reader.result;
            }
            reader.readAsDataURL(event.target.files[0]);
        }

        function removeImage() {
            document.getElementById('profile-preview').src = 'https://ui-avatars.com/api/?name=S&background=E11D48&color=fff';
        }

        function saveProfile() {
            const btn = document.getElementById('save-btn');
            const text = document.getElementById('btn-text');
            const loader = document.getElementById('btn-loader');
            const toast = document.getElementById('toast');

            // Loading State
            btn.disabled = true;
            text.innerText = 'Syncing...';
            loader.classList.remove('hidden');

            setTimeout(() => {
                // Success State
                loader.classList.add('hidden');
                text.innerText = 'Updated! ❤️';
                btn.classList.add('bg-green-500');

                toast.style.display = 'block';
                navigator.vibrate?.([50, 30, 50]);

                setTimeout(() => {
                    window.location.href = '/profile';
                }, 1500);
            }, 2000);
        }
    </script>
</body>

</html>