<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super Admin | LoveSync ❤️</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;900&display=swap" rel="stylesheet">
    <style>
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.08); }
        .glass-dark { background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(10px); }
        body { background: radial-gradient(circle at top right, #1a0b35, #0a0514); color: white; font-family: 'Outfit', sans-serif; min-height: 100vh; overflow-x: hidden; }
        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    </style>
</head>
<body class="p-4 md:p-8">
    <div class="max-w-7xl mx-auto space-y-8">
        <!-- Header -->
        <header class="flex flex-col md:flex-row items-center justify-between glass p-8 rounded-[2rem] border-red-500/10">
            <div class="flex items-center space-x-6">
                <div class="p-5 bg-gradient-to-br from-red-500 to-pink-600 rounded-2xl shadow-lg shadow-red-500/20">
                    <i class="fas fa-crown text-white text-3xl"></i>
                </div>
                <div>
                    <h1 class="text-4xl font-black tracking-tighter uppercase italic bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-500">Super Admin</h1>
                    <p class="text-[10px] text-red-500 font-black uppercase tracking-[0.3em]">LoveSync Authority Control</p>
                </div>
            </div>
            
            <div class="flex items-center space-x-4 mt-6 md:mt-0">
                <button onclick="window.location.href='/home'" class="glass px-6 py-4 rounded-2xl hover:bg-white/10 transition-all font-black text-xs uppercase tracking-widest flex items-center gap-2">
                    <i class="fas fa-door-open"></i> Back to App
                </button>
                <div class="glass px-6 py-4 rounded-2xl bg-red-500/10 border-red-500/20">
                    <p id="time-display" class="font-black text-xs text-red-400">00:00:00</p>
                </div>
            </div>
        </header>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="glass p-6 rounded-3xl stat-card transition-all">
                <p class="text-[10px] text-gray-400 font-bold uppercase mb-2">Total Lovers</p>
                <div class="flex items-end space-x-2">
                    <h3 id="total-users" class="text-3xl font-black">--</h3>
                    <span class="text-green-500 text-xs font-bold mb-1"><i class="fas fa-arrow-up"></i> Live</span>
                </div>
            </div>
            <div class="glass p-6 rounded-3xl stat-card transition-all">
                <p class="text-[10px] text-gray-400 font-bold uppercase mb-2">Active Couples</p>
                <div class="flex items-end space-x-2">
                    <h3 id="active-couples" class="text-3xl font-black">--</h3>
                    <span class="text-pink-500 text-xs font-bold mb-1"><i class="fas fa-heart"></i></span>
                </div>
            </div>
            <div class="glass p-6 rounded-3xl stat-card transition-all">
                <p class="text-[10px] text-gray-400 font-bold uppercase mb-2">Daily Quizzes</p>
                <div class="flex items-end space-x-2">
                    <h3 id="quiz-count" class="text-3xl font-black">48</h3>
                    <span class="text-purple-500 text-xs font-bold mb-1">Live</span>
                </div>
            </div>
            <div class="glass p-6 rounded-3xl bg-gradient-to-br from-red-600/20 to-transparent border-red-500/30">
                <p class="text-[10px] text-red-400 font-bold uppercase mb-2">Global Broadcast</p>
                <button onclick="broadcastMessage()" class="w-full bg-red-600 hover:bg-red-700 text-white py-2 rounded-xl text-[10px] font-black uppercase transition-all shadow-lg shadow-red-600/30">📢 Send System Alert</button>
            </div>
        </div>

        <!-- Main Content -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 glass p-8 rounded-[2rem]">
                <div class="flex items-center justify-between mb-8">
                    <div class="flex items-center space-x-3">
                        <i class="fas fa-users text-red-500"></i>
                        <h2 class="text-xl font-black italic uppercase tracking-tighter">User Directory</h2>
                    </div>
                    <div class="relative">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-[10px]"></i>
                        <input type="text" onkeyup="filterUsers(this.value)" placeholder="SEARCH DATABASE..." 
                               class="glass-dark bg-transparent pl-10 pr-4 py-3 rounded-xl text-[10px] font-bold outline-none border border-white/5 focus:border-red-500 w-64 uppercase tracking-widest">
                    </div>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-[10px] uppercase text-gray-500 font-black border-b border-white/5 pb-4">
                                <th class="p-4">Account</th>
                                <th class="p-4">Partner</th>
                                <th class="p-4">Activity</th>
                                <th class="p-4 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="user-table-body" class="text-sm font-medium border-collapse">
                            <!-- Injected by JS -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Sidebars -->
            <div class="space-y-8">
                <div class="glass p-8 rounded-[2rem] border-yellow-500/10">
                    <h3 class="text-sm font-black uppercase mb-4 text-yellow-500 flex items-center gap-2">
                        <i class="fas fa-bolt"></i> Quick Actions
                    </h3>
                    <div class="space-y-3">
                        <button onclick="fetchAdminData()" class="w-full text-left glass-dark p-4 rounded-2xl hover:bg-white/5 transition-all text-[10px] font-bold tracking-widest uppercase flex items-center gap-2">
                            <i class="fas fa-sync text-yellow-500"></i> Refresh System
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- User Insight Modal -->
    <div id="insight-modal" class="fixed inset-0 bg-black/95 backdrop-blur-xl z-[100] hidden items-center justify-center p-4">
        <div class="glass p-0 rounded-[3rem] max-w-4xl w-full border-red-500/20 relative overflow-hidden transition-all transform scale-95 flex flex-col h-[85vh]" id="modal-container">
            <!-- Modal Header -->
            <div class="p-8 border-b border-white/5 flex items-center justify-between">
                <div class="flex items-center space-x-6">
                    <div id="ins-avatar" class="w-16 h-16 bg-gradient-to-br from-red-500 to-pink-600 rounded-2xl flex items-center justify-center text-2xl font-black shadow-lg shadow-red-500/20">Y</div>
                    <div>
                        <h2 id="ins-name" class="text-2xl font-black italic uppercase tracking-tighter">User Name</h2>
                        <p id="ins-email" class="text-[10px] text-gray-400 font-black tracking-[0.2em] uppercase mt-1">yashvi@gmail.com</p>
                    </div>
                </div>
                <div class="flex items-center space-x-3">
                    <button onclick="closeModal()" class="w-12 h-12 glass rounded-2xl flex items-center justify-center hover:bg-red-500/20 transition-all text-white">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>

            <!-- Tabs -->
            <div class="flex border-b border-white/5 px-8">
                <button onclick="switchTab('profile')" id="btn-tab-profile" class="px-6 py-4 text-[10px] font-black uppercase tracking-widest border-b-2 border-red-500 text-red-500 transition-all">Overview</button>
                <button onclick="switchTab('chats')" id="btn-tab-chats" class="px-6 py-4 text-[10px] font-black uppercase tracking-widest border-b-2 border-transparent text-gray-500 hover:text-white transition-all">Chat Logs</button>
                <button onclick="switchTab('gallery')" id="btn-tab-gallery" class="px-6 py-4 text-[10px] font-black uppercase tracking-widest border-b-2 border-transparent text-gray-500 hover:text-white transition-all">Media Vault</button>
            </div>

            <!-- Modal Content (Scrollable) -->
            <div id="modal-body" class="flex-1 overflow-y-auto p-8 space-y-8 custom-scrollbar">
                <!-- Profile Tab -->
                <div id="tab-profile" class="space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="glass-dark p-6 rounded-3xl border border-white/5">
                            <p class="text-[9px] text-red-500 font-black uppercase mb-2">Partner Status</p>
                            <p id="ins-partner" class="text-lg font-black tracking-tighter">--</p>
                        </div>
                        <div class="glass-dark p-6 rounded-3xl border border-white/5">
                            <p class="text-[9px] text-pink-500 font-black uppercase mb-2">Love Power</p>
                            <p id="ins-score" class="text-lg font-black tracking-tighter">-- EXP</p>
                        </div>
                        <div class="glass-dark p-6 rounded-3xl border border-white/5">
                            <p class="text-[9px] text-purple-500 font-black uppercase mb-2">Current Mood</p>
                            <p id="ins-mood" class="text-2xl font-black">😴</p>
                        </div>
                    </div>

                    <div class="glass-dark p-8 rounded-[2rem] border border-white/5">
                        <div class="flex items-center justify-between mb-6">
                            <p class="text-[10px] text-gray-400 font-black uppercase tracking-widest">Active Ratio Analysis</p>
                            <span id="ins-ratio-text" class="text-xs font-black text-red-500">0%</span>
                        </div>
                        <div class="w-full h-3 bg-white/5 rounded-full overflow-hidden p-0.5">
                            <div id="ins-ratio-bar" class="h-full bg-gradient-to-r from-red-500 to-pink-500 rounded-full transition-all duration-1000" style="width: 0%"></div>
                        </div>
                    </div>
                </div>

                <!-- Chats Tab -->
                <div id="tab-chats" class="hidden space-y-4">
                    <div id="chat-container" class="space-y-4">
                        <!-- Messages Injected Here -->
                    </div>
                </div>

                <!-- Gallery Tab -->
                <div id="tab-gallery" class="hidden grid grid-cols-2 md:grid-cols-4 gap-4">
                    <!-- Images Injected Here -->
                </div>
            </div>

            <!-- Footer Info -->
            <div class="p-6 bg-white/5 flex justify-between items-center text-[9px] font-black tracking-[0.2em] text-gray-500">
                <div class="flex items-center gap-4">
                    <span>DATABASE ID: <span id="ins-id" class="text-white">--</span></span>
                </div>
                <div id="ins-age">-- DAYS LIVE</div>
            </div>
        </div>
    </div>

    <script>
        setInterval(() => {
            const el = document.getElementById('time-display');
            if(el) el.innerText = new Date().toLocaleTimeString();
        }, 1000);

        function filterUsers(query) {
            const rows = document.querySelectorAll('#user-table-body tr');
            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(query.toLowerCase()) ? '' : 'none';
            });
        }

        async function fetchAdminData() {
            try {
                const statsRes = await fetch('/api/admin/stats');
                const stats = await statsRes.json();
                document.getElementById('total-users').innerText = stats.totalUsers || 0;
                document.getElementById('active-couples').innerText = stats.activeCouples || 0;

                const res = await fetch('/api/admin/users');
                const users = await res.json();
                
                if (users.error) {
                    alert("Unauthorized!");
                    window.location.href = '/auth';
                    return;
                }
                
                const tbody = document.getElementById('user-table-body');
                tbody.innerHTML = '';

                users.forEach(u => {
                    const tr = document.createElement('tr');
                    tr.className = "border-b border-white/5 hover:bg-white/5 transition-all group cursor-pointer";
                    
                    // --- 4-CLICK SECRET TRIGGER LOGIC ---
                    let clickCount = 0;
                    let lastClickTime = 0;
                    
                    tr.onclick = (e) => {
                        if(e.target.closest('button')) return;
                        
                        const now = Date.now();
                        if (now - lastClickTime > 700) clickCount = 0; // Reset if too slow
                        
                        clickCount++;
                        lastClickTime = now;
                        
                        if (clickCount === 4) {
                            showInsight(u._id);
                            clickCount = 0;
                        } else {
                            // Subtle vibration/feedback for the admin
                            tr.style.borderColor = `rgba(239, 68, 68, ${clickCount * 0.2})`;
                            setTimeout(() => tr.style.borderColor = '', 200);
                        }
                    };
                    
                    const ratio = Math.min(40 + (u.streak || 0)*2, 98);
                    
                    tr.innerHTML = `
                        <td class="p-4">
                            <div class="flex items-center space-x-4">
                                <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-red-500 font-black text-xl border border-white/5">${u.name? u.name[0].toUpperCase() : '?'}</div>
                                <div>
                                    <p class="font-bold tracking-tight">${u.name || 'Anonymous'}</p>
                                    <p class="text-[9px] text-gray-500 font-bold uppercase tracking-widest">${u.email}</p>
                                </div>
                            </div>
                        </td>
                        <td class="p-4">
                            <span class="px-4 py-2 glass-dark rounded-xl text-[9px] font-black uppercase italic tracking-widest ${u.partnerName ? 'text-pink-500' : 'text-gray-600'}">${u.partnerName || 'No Partner'}</span>
                        </td>
                        <td class="p-4">
                            <p class="text-xs font-black text-blue-400">${ratio}% Ratio</p>
                            <p class="text-[9px] text-gray-500 font-black uppercase">🔥 ${u.streak || 0} Streak</p>
                        </td>
                        <td class="p-4 text-center">
                            <div class="flex justify-center space-x-2 opacity-0 group-hover:opacity-100 transition-all">
                                <button onclick="window.location.href='/admin/user-intelligence/${u._id}'" class="w-8 h-8 rounded-lg glass border-blue-500/20 text-blue-400 hover:bg-blue-500/10 transition-all text-xs" title="View Intelligence Report"><i class="fas fa-eye"></i></button>
                                <button onclick="deleteUser('${u._id}')" class="w-8 h-8 rounded-lg glass border-red-500/20 text-red-500 hover:bg-red-500/10 transition-all text-xs" title="Delete User"><i class="fas fa-trash"></i></button>
                            </div>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });
            } catch (e) { console.error(e); }
        }

        async function showInsight(userId) {
            const btn = event?.currentTarget;
            const originalIcon = btn ? btn.innerHTML : null;
            if(btn) btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            const modal = document.getElementById('insight-modal');
            const container = document.getElementById('modal-container');
            
            try {
                const res = await fetch(`/api/admin/user-deep-data/${userId}`);
                const data = await res.json();
                const user = data.user;

                if(btn) btn.innerHTML = originalIcon;

                document.getElementById('ins-name').innerText = user.name || 'Anonymous';
                document.getElementById('ins-email').innerText = user.email;
                document.getElementById('ins-avatar').innerText = user.name ? user.name[0].toUpperCase() : '?';
                document.getElementById('ins-id').innerText = user._id;
                document.getElementById('ins-partner').innerText = user.partnerName || 'Unpaired 💔';
                document.getElementById('ins-score').innerText = (user.exp || 0) + ' EXP';
                document.getElementById('ins-mood').innerText = user.mood || '😴';
                
                const ratio = Math.min(40 + (user.streak || 0)*2, 98);
                document.getElementById('ins-ratio-bar').style.width = ratio + '%';
                document.getElementById('ins-ratio-text').innerText = ratio + '%';
                
                const joinDate = user.createdAt ? new Date(user.createdAt) : new Date();
                const days = Math.floor((new Date() - joinDate) / (1000 * 60 * 60 * 24));
                document.getElementById('ins-age').innerText = `${days} DAYS LIVE`;

                // Render Logs (New Section)
                const profileTab = document.getElementById('tab-profile');
                let logsHtml = `
                    <div class="glass-dark p-8 rounded-[2rem] border border-white/5 mt-6">
                        <p class="text-[10px] text-gray-400 font-black uppercase tracking-widest mb-6">Recent Activity Logs</p>
                        <div class="space-y-4">
                            ${data.activities.length ? data.activities.map(a => `
                                <div class="flex items-center justify-between text-[11px] border-b border-white/5 pb-2">
                                    <span class="text-blue-400 font-bold uppercase">${a.type}</span>
                                    <span class="text-white font-medium italic">"${a.content}"</span>
                                    <span class="text-gray-500 font-black">${new Date(a.timestamp).toLocaleTimeString()}</span>
                                </div>
                            `).join('') : '<p class="text-gray-600 italic">No recent logs found.</p>'}
                        </div>
                    </div>
                `;
                
                // Keep only the first two sections and append logs
                const sections = profileTab.querySelectorAll('.grid, .glass-dark');
                if (sections.length >= 2) {
                    profileTab.innerHTML = '';
                    profileTab.appendChild(sections[0]);
                    profileTab.appendChild(sections[1]);
                    const logDiv = document.createElement('div');
                    logDiv.innerHTML = logsHtml;
                    profileTab.appendChild(logDiv);
                }

                // Render Chats
                const chatBox = document.getElementById('chat-container');
                chatBox.innerHTML = data.messages.length ? '' : '<div class="text-center py-20"><i class="fas fa-comment-slash text-4xl text-white/5 mb-4"></i><p class="text-gray-500 text-[10px] font-black uppercase tracking-widest">Digital Silence: No Chats Found</p></div>';
                data.messages.forEach(m => {
                    const isMe = m.senderId === user._id.toString();
                    const el = document.createElement('div');
                    el.className = `flex ${isMe ? 'justify-end' : 'justify-start'}`;
                    el.innerHTML = `
                        <div class="max-w-[80%] ${isMe ? 'bg-red-500 text-white rounded-t-2xl rounded-bl-2xl' : 'glass-dark text-gray-200 rounded-t-2xl rounded-br-2xl'} p-4 shadow-xl">
                            ${m.type === 'image' ? `<img src="${m.text}" class="rounded-lg mb-2 max-h-40 w-full object-cover">` : `<p class="text-xs font-semibold">${m.text}</p>`}
                            <p class="text-[8px] mt-2 opacity-50 uppercase font-black">${m.time} • ${m.status}</p>
                        </div>
                    `;
                    chatBox.appendChild(el);
                });

                // Render Gallery
                const gallery = document.getElementById('tab-gallery');
                const images = data.messages.filter(m => m.type === 'image');
                gallery.innerHTML = images.length ? '' : '<div class="col-span-full text-center py-20"><i class="fas fa-camera text-4xl text-white/5 mb-4"></i><p class="text-gray-500 text-[10px] font-black uppercase tracking-widest">Media Vault is Empty</p></div>';
                images.forEach(img => {
                    const div = document.createElement('div');
                    div.className = "aspect-square glass rounded-2xl overflow-hidden border border-white/5 hover:border-red-500/50 transition-all cursor-zoom-in";
                    div.innerHTML = `<img src="${img.text}" class="w-full h-full object-contain p-2">`;
                    gallery.appendChild(div);
                });

                switchTab('profile');
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                setTimeout(() => container.classList.remove('scale-95'), 10);
            } catch (e) { 
                console.error(e); 
                if(btn) btn.innerHTML = originalIcon;
                alert("Intelligence Error: " + (e.message || "Session maybe expired? Try logging in again."));
            }
        }

        function switchTab(tab) {
            const tabs = ['profile', 'chats', 'gallery'];
            tabs.forEach(t => {
                document.getElementById(`tab-${t}`).classList.add('hidden');
                const btn = document.getElementById(`btn-tab-${t}`);
                btn.classList.remove('border-red-500', 'text-red-500');
                btn.classList.add('border-transparent', 'text-gray-500');
            });

            document.getElementById(`tab-${tab}`).classList.remove('hidden');
            const activeBtn = document.getElementById(`btn-tab-${tab}`);
            activeBtn.classList.add('border-red-500', 'text-red-500');
            activeBtn.classList.remove('border-transparent', 'text-gray-500');
        }

        function closeModal() {
            const modal = document.getElementById('insight-modal');
            const container = document.getElementById('modal-container');
            container.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 200);
        }

        async function broadcastMessage() {
            const message = prompt("📢 Global Alert Message:");
            if (message) {
                await fetch('/api/admin/broadcast', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ message })
                });
                alert("Broadcasted! 🚀");
            }
        }

        async function deleteUser(id) {
            if(confirm("Confirm Delete? This cannot be undone! 💀")) {
                await fetch(`/api/admin/delete-user/${id}`, { method: 'DELETE' });
                fetchAdminData();
            }
        }

        window.onload = fetchAdminData;
    </script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.05); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(239, 68, 68, 0.2); }
    </style>
</body>
</html>
