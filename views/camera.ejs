<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Camera | LoveSync ❤️</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800;900&display=swap"
        rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    colors: {
                        'brand-pink': '#E11D48',
                        'dark-bg': '#0a0514'
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background: #000;
            overflow: hidden;
            height: 100vh;
            width: 100vw;
        }

        #video-feed {
            position: fixed;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 0;
        }

        .mirrored {
            transform: scaleX(-1);
        }

        .glass-ui {
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .capture-rim {
            width: 84px;
            height: 84px;
            border-radius: 50%;
            border: 4px solid #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s cubic-bezier(0.1, 0.7, 0.6, 0.9);
        }

        .capture-btn {
            width: 66px;
            height: 66px;
            background: #fff;
            border-radius: 50%;
            transition: all 0.2s;
        }

        .capture-rim:active {
            transform: scale(1.1);
        }

        .capture-rim:active .capture-btn {
            transform: scale(0.85);
            background: #E11D48;
        }

        .mode-active {
            color: #fff;
            font-weight: 900;
        }

        .mode-inactive {
            color: rgba(255, 255, 255, 0.5);
            font-weight: 600;
        }

        #toast-container {
            position: fixed;
            top: 5rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1000;
        }

        @keyframes capture-flash {
            0% {
                opacity: 0;
            }

            50% {
                opacity: 1;
            }

            100% {
                opacity: 0;
            }
        }

        .flash-overlay {
            position: fixed;
            inset: 0;
            background: #fff;
            z-index: 999;
            opacity: 0;
            pointer-events: none;
        }

        .do-flash {
            animation: capture-flash 0.3s ease-out;
        }

        #preview-image {
            position: fixed;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 10;
        }
    </style>
</head>

<body class="text-white select-none touch-none">

    <div id="flash-screen" class="flash-overlay"></div>
    <div id="toast-container"></div>
    <audio id="shutter-sound" src="https://assets.mixkit.net/sfx/preview/mixkit-camera-shutter-click-1133.mp3"></audio>

    <video id="video-feed" autoplay playsinline muted></video>

    <!-- TOP CONTROLS -->
    <div class="fixed top-0 left-0 right-0 p-6 flex items-center justify-between z-50">
        <a href="/home" class="w-10 h-10 glass-ui rounded-full flex items-center justify-center">
            <i class="fas fa-times text-lg"></i>
        </a>

        <div class="flex items-center space-x-4">
            <button id="flash-btn" class="w-10 h-10 glass-ui rounded-full flex items-center justify-center">
                <i class="fas fa-bolt text-lg"></i>
            </button>
            <button class="w-10 h-10 glass-ui rounded-full flex items-center justify-center">
                <i class="fas fa-cog text-lg"></i>
            </button>
        </div>
    </div>

    <!-- CENTER FILTERS CAROUSEL -->
    <div
        class="fixed bottom-40 left-0 right-0 flex items-center space-x-4 px-10 overflow-x-auto no-scrollbar z-50 pb-4">
        <button onclick="applyFilter('none')"
            class="flex-shrink-0 w-12 h-12 rounded-full border-2 border-white/50 bg-white/10 flex items-center justify-center text-[10px] font-bold">None</button>
        <button onclick="applyFilter('love')"
            class="flex-shrink-0 w-12 h-12 rounded-full border-2 border-white/10 bg-brand-pink/20 flex items-center justify-center text-[10px] font-bold">Love</button>
        <button onclick="applyFilter('dreamy')"
            class="flex-shrink-0 w-12 h-12 rounded-full border-2 border-white/10 bg-blue-500/20 flex items-center justify-center text-[10px] font-bold">Dream</button>
        <button onclick="applyFilter('neon')"
            class="flex-shrink-0 w-12 h-12 rounded-full border-2 border-white/10 bg-purple-500/20 flex items-center justify-center text-[10px] font-bold">Neon</button>
        <button onclick="applyFilter('sunset')"
            class="flex-shrink-0 w-12 h-12 rounded-full border-2 border-white/10 bg-orange-500/20 flex items-center justify-center text-[10px] font-bold">Warm</button>
    </div>

    <!-- BOTTOM UI -->
    <div
        class="fixed bottom-0 left-0 right-0 p-8 pb-12 flex flex-col items-center space-y-8 z-50 bg-gradient-to-t from-black/80 to-transparent">

        <!-- MODE SELECTOR -->
        <div class="flex items-center space-x-8 text-[11px] uppercase tracking-[0.2em]">
            <span class="mode-inactive opacity-50">Video</span>
            <span class="mode-active text-brand-pink border-b-2 border-brand-pink pb-1">Photo</span>
            <span class="mode-inactive opacity-50">Quiz</span>
        </div>

        <!-- MAIN ACTIONS -->
        <div class="w-full flex items-center justify-between">
            <button class="w-12 h-12 glass-ui rounded-2xl flex items-center justify-center overflow-hidden">
                <img src="/images/partner-avatar.png" class="w-8 h-8 rounded-lg opacity-50">
            </button>

            <div id="capture-rim" class="capture-rim shadow-2xl">
                <div class="capture-btn"></div>
            </div>

            <button id="flip-btn" class="w-12 h-12 glass-ui rounded-full flex items-center justify-center">
                <i class="fas fa-sync-alt text-lg"></i>
            </button>
        </div>
    </div>

    <!-- PREVIEW SCREEN -->
    <div id="preview-screen" class="fixed inset-0 z-[100] hidden bg-black">
        <canvas id="preview-image"></canvas>

        <!-- PREVIEW TOP -->
        <div class="fixed top-0 left-0 right-0 p-6 flex items-center justify-between z-[110]">
            <button id="cancel-preview" class="w-10 h-10 glass-ui rounded-full flex items-center justify-center">
                <i class="fas fa-times text-lg"></i>
            </button>
            <div class="flex space-x-3">
                <button class="w-10 h-10 glass-ui rounded-full flex items-center justify-center"><i
                        class="fas fa-pen text-xs"></i></button>
                <button class="w-10 h-10 glass-ui rounded-full flex items-center justify-center"><i
                        class="fas fa-smile text-xs"></i></button>
            </div>
        </div>

        <!-- PREVIEW BOTTOM -->
        <div class="fixed bottom-10 left-0 right-0 px-8 flex items-center justify-between z-[110]">
            <button id="retake-btn"
                class="bg-white/10 backdrop-blur-xl px-6 py-4 rounded-2xl border border-white/20 font-black uppercase text-[10px] tracking-widest">
                Retake
            </button>
            <button onclick="sendSnap()"
                class="flex-1 ml-4 bg-brand-pink py-4 rounded-2xl font-black uppercase text-xs tracking-widest shadow-lg shadow-brand-pink/40 animate-pulse">
                Send to Partner ❤️
            </button>
        </div>
    </div>

    <script>
        const video = document.getElementById('video-feed');
        const flipBtn = document.getElementById('flip-btn');
        const captureRim = document.getElementById('capture-rim');
        const previewScreen = document.getElementById('preview-screen');
        const previewCanvas = document.getElementById('preview-image');
        const flashScreen = document.getElementById('flash-screen');

        let currentMode = 'user';
        let stream = null;
        let currentFilter = 'none';

        async function initCamera() {
            if (stream) stream.getTracks().forEach(t => t.stop());
            try {
                stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: currentMode },
                    audio: false
                });
                video.srcObject = stream;
                if (currentMode === 'user') video.classList.add('mirrored');
                else video.classList.remove('mirrored');
            } catch (err) {
                alert("Camera Access Required! 📸");
            }
        }

        flipBtn.onclick = () => {
            currentMode = currentMode === 'user' ? 'environment' : 'user';
            initCamera();
        };

        function applyFilter(filter) {
            currentFilter = filter;
            video.style.filter = getFilterCSS(filter);
            navigator.vibrate?.(10);
        }

        function getFilterCSS(type) {
            switch (type) {
                case 'love': return 'sepia(0.3) saturate(1.8) hue-rotate(-30deg)';
                case 'dreamy': return 'brightness(1.2) saturate(1.2) blur(0.5px)';
                case 'neon': return 'contrast(1.5) brightness(1.1) hue-rotate(90deg)';
                case 'sunset': return 'sepia(0.5) contrast(1.1) hue-rotate(-15deg)';
                default: return 'none';
            }
        }

        captureRim.onclick = () => {
            document.getElementById('shutter-sound').play();
            flashScreen.classList.add('do-flash');
            setTimeout(() => flashScreen.classList.remove('do-flash'), 300);
            navigator.vibrate?.(50);

            const ctx = previewCanvas.getContext('2d');
            previewCanvas.width = video.videoWidth;
            previewCanvas.height = video.videoHeight;

            if (currentMode === 'user') {
                ctx.translate(previewCanvas.width, 0);
                ctx.scale(-1, 1);
            }

            // Apply filter to canvas capture if needed, or use CSS on canvas
            previewCanvas.style.filter = getFilterCSS(currentFilter);
            ctx.drawImage(video, 0, 0);

            previewScreen.style.display = 'block';
        };

        document.getElementById('cancel-preview').onclick = () => previewScreen.style.display = 'none';
        document.getElementById('retake-btn').onclick = () => previewScreen.style.display = 'none';

        function showToast(msg) {
            const container = document.getElementById('toast-container');
            const t = document.createElement('div');
            t.className = "bg-brand-pink/90 backdrop-blur-xl px-8 py-3 rounded-full font-black text-[10px] uppercase tracking-widest shadow-2xl animate-bounce";
            t.innerText = msg;
            container.appendChild(t);
            setTimeout(() => t.remove(), 3000);
        }

        function sendSnap() {
            showToast("Snap Sent to Partner! 🏹❤️");
            setTimeout(() => previewScreen.style.display = 'none', 1500);
        }

        initCamera();
    </script>
</body>

</html>