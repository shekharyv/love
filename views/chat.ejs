        socket.on('incoming-call', (data) => {
            const modal = document.getElementById('incoming-call-modal');
            document.getElementById('caller-name-text').innerText = data.callerName;
            document.getElementById('call-type-label').innerText = `Incoming ${data.callType} call...`;
            modal.classList.remove('hidden');
            vibrateDevice();
            
            window.acceptCall = async () => {
                modal.classList.add('hidden');
                socket.emit('accept-call', { to: data.from, channelName: data.channelName, callType: data.callType });
                startAgoraCall(data.channelName, data.callType);
            };

            window.rejectCall = () => {
                modal.classList.add('hidden');
                socket.emit('reject-call', { to: data.from });
            };
        });

        socket.on('call-accepted', (data) => {
            hideCallStatus();
            startAgoraCall(data.channelName, data.callType);
        });

        socket.on('call-rejected', () => {
            showCallStatus('Call Rejected ❌', false);
            setTimeout(hideCallStatus, 2000);
        });

        socket.on('end-call-signal', () => leaveCall(false));

        async function startAgoraCall(channelName, type) {
            document.getElementById('active-call-overlay').classList.remove('hidden');
            try {
                const res = await fetch(`/api/agora-token?channelName=${channelName}&uid=0`);
                const { token, appId } = await res.json();
                await agoraClient.join(appId, channelName, token, null);
                
                localTracks.audioTrack = await AgoraRTC.createMicrophoneAudioTrack();
                if (type === 'video') {
                    localTracks.videoTrack = await AgoraRTC.createCameraVideoTrack();
                    localTracks.videoTrack.play('local-video-container');
                    await agoraClient.publish([localTracks.audioTrack, localTracks.videoTrack]);
                } else {
                    await agoraClient.publish([localTracks.audioTrack]);
                    document.getElementById('local-video-container').innerHTML = `<div class="w-full h-full flex items-center justify-center bg-gray-900"><i class="fas fa-user-circle text-6xl text-brand-pink"></i></div>`;
                }

                agoraClient.on("user-published", async (user, mediaType) => {
                    await agoraClient.subscribe(user, mediaType);
                    if (mediaType === "video") user.videoTrack.play('remote-video-container');
                    if (mediaType === "audio") user.audioTrack.play();
                });
            } catch (err) { leaveCall(); }
        }

        async function leaveCall(notify = true) {
            for (let trackName in localTracks) {
                if (localTracks[trackName]) {
                    localTracks[trackName].stop();
                    localTracks[trackName].close();
                    localTracks[trackName] = null;
                }
            }
            await agoraClient.leave();
            document.getElementById('active-call-overlay').classList.add('hidden');
            if (notify) socket.emit('end-call', { to: PARTNER_ID });
        }

        function toggleMute() {
            isAudioMuted = !isAudioMuted;
            localTracks.audioTrack.setEnabled(!isAudioMuted);
            document.getElementById('mute-btn').innerHTML = isAudioMuted ? '<i class="fas fa-microphone-slash"></i>' : '<i class="fas fa-microphone"></i>';
        }

        function toggleVideo() {
            isVideoMuted = !isVideoMuted;
            if (localTracks.videoTrack) {
                localTracks.videoTrack.setEnabled(!isVideoMuted);
                document.getElementById('video-toggle-btn').innerHTML = isVideoMuted ? '<i class="fas fa-video-slash"></i>' : '<i class="fas fa-video"></i>';
            }
        }

        function showCallStatus(text) {
            const status = document.getElementById('call-status-indicator');
            status.innerText = text;
            status.classList.remove('hidden');
        }
        function hideCallStatus() { document.getElementById('call-status-indicator').classList.add('hidden'); }

        window.addEventListener('load', () => {
            initChat();
            markAsDelivered();
            setInterval(loadMessages, 1500);
        });
    </script>


    <!-- Snap Viewer Overlay (View Once) -->
    <div id="snap-viewer"
        class="hidden fixed inset-0 z-[200] bg-black/95 flex items-center justify-center animate-fadeIn">
        <div class="relative w-full h-full flex flex-col items-center justify-center p-4">
            <img id="view-snap-img" src=""
                class="max-w-full max-h-[85vh] rounded-3xl object-contain border border-white/10 shadow-2xl" />
            <div class="mt-8 flex flex-col items-center">
                <div class="flex items-center space-x-3 mb-2">
                    <div class="w-10 h-10 rounded-full border-t-2 border-brand-pink animate-spin"></div>
                    <span class="text-white font-black uppercase tracking-widest text-xs">Self-destructing...</span>
                </div>
                <p id="snap-timer-text" class="text-brand-pink font-black text-4xl">3</p>
            </div>
        </div>
    </div>

    <!-- AI Quiz Modal -->
    <div id="quiz-modal"
        class="hidden fixed inset-0 z-[300] bg-[#0a0514]/98 backdrop-blur-xl flex items-center justify-center p-6 animate-fadeIn">
        <div class="w-full max-w-sm flex flex-col items-center text-center space-y-8">
            <div class="relative w-32 h-32 flex items-center justify-center">
                <div class="absolute inset-0 bg-brand-pink/20 rounded-full blur-3xl animate-pulse"></div>
                <div
                    class="w-16 h-16 bg-brand-pink/20 border-2 border-brand-pink/40 rounded-3xl flex items-center justify-center text-brand-pink shadow-2xl animate-bounce">
                    <i class="fas fa-brain text-2xl"></i>
                </div>
            </div>

            <div class="space-y-2">
                <p id="quiz-progress" class="text-[10px] font-black uppercase tracking-widest text-brand-pink/60">
                    Question 1 of 10</p>
                <div class="w-24 h-1 bg-white/10 mx-auto rounded-full overflow-hidden">
                    <div id="quiz-progress-bar" class="w-1/10 h-full bg-brand-pink transition-all duration-500"></div>
                </div>
            </div>

            <h2 id="quiz-question-text"
                class="text-xl font-bold text-white leading-snug min-h-[100px] flex items-center justify-center italic px-4">
                Loading your romantic quiz... 💭
            </h2>

            <div class="flex flex-col w-full space-y-4 pt-8">
                <button onclick="nextQuizQuestion()"
                    class="w-full py-4 bg-gradient-to-r from-brand-pink to-brand-purple rounded-3xl font-black text-xs uppercase tracking-widest shadow-xl shadow-brand-pink/20 transition-all hover:scale-[1.02] active:scale-95 group flex items-center justify-center space-x-3">
                    <span id="quiz-btn-text">Answered! Next ❤️</span>
                    <i class="fas fa-arrow-right text-[10px]"></i>
                </button>
                <button onclick="closeQuiz()"
                    class="text-[10px] font-bold text-gray-500 uppercase tracking-widest hover:text-white transition-colors">Close
                    Game</button>
            </div>
        </div>
    </div>
    <!-- --- AGORA CALL UI COMPONENTS --- -->
    <div id="incoming-call-modal" class="hidden fixed inset-0 z-[500] bg-black/80 backdrop-blur-md flex items-center justify-center p-6">
        <div class="w-full max-w-xs bg-[#1a1025] border border-white/10 rounded-[3rem] p-8 flex flex-col items-center text-center space-y-6">
            <div class="relative"><div class="absolute inset-0 bg-brand-pink/20 rounded-full blur-2xl animate-pulse"></div><img src="/images/partner-avatar.png" class="w-24 h-24 rounded-full border-4 border-brand-pink relative"></div>
            <div><h2 id="caller-name-text" class="text-2xl font-black text-white">Partner</h2><p id="call-type-label" class="text-gray-400 text-sm mt-1 uppercase tracking-widest font-bold font-sans">Incoming Call...</p></div>
            <div class="flex space-x-4 w-full"><button onclick="rejectCall()" class="flex-1 bg-red-500/20 text-red-500 py-4 rounded-3xl"><i class="fas fa-times"></i></button><button onclick="acceptCall()" class="flex-1 bg-green-500 text-white py-4 rounded-3xl animate-bounce"><i class="fas fa-phone"></i></button></div>
        </div>
    </div>

    <div id="active-call-overlay" class="hidden fixed inset-0 z-[600] bg-black">
        <div id="remote-video-container" class="w-full h-full bg-gray-900"></div>
        <div id="local-video-container" class="absolute top-8 right-6 w-32 h-44 bg-black rounded-2xl overflow-hidden border-2 border-white/20 z-10"></div>
        <div class="absolute bottom-12 left-0 right-0 flex justify-center items-center space-x-6 z-20">
            <button id="mute-btn" onclick="toggleMute()" class="w-14 h-14 rounded-full bg-white/10 border border-white/20 text-white flex items-center justify-center"><i class="fas fa-microphone"></i></button>
            <button onclick="leaveCall()" class="w-16 h-16 rounded-full bg-red-500 text-white flex items-center justify-center"><i class="fas fa-phone-slash rotate-[135deg]"></i></button>
            <button id="video-toggle-btn" onclick="toggleVideo()" class="w-14 h-14 rounded-full bg-white/10 border border-white/20 text-white flex items-center justify-center"><i class="fas fa-video"></i></button>
        </div>
    </div>

    <div id="call-status-indicator" class="hidden fixed top-24 left-1/2 -translate-x-1/2 z-[400] bg-brand-pink text-white px-6 py-2 rounded-full font-black text-[10px] uppercase tracking-widest">Calling...</div>

</body>


</html>