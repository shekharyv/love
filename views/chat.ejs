<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat | LoveSync ❤️</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <!-- --- AGORA & PWA REGISTRATION --- -->
    <script src="https://download.agora.io/sdk/release/AgoraRTC_N-4.18.2.js"></script>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#ff007f">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').then(reg => {
                    console.log('✅ PWA: Service Worker Registered! Offline Mode Active. 🕵️‍♂️🛡️');
                }).catch(err => console.log('🛑 PWA: Registration Failed.', err));
            });
        }
    </script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        'brand-purple': '#4D128B',
                        'brand-pink': '#E11D48',
                        'neon-pink': '#FF007F',
                        'neon-purple': '#9D50BB',
                    }
                }
            }
        }
    </script>
    <style>
        .heart {
            position: absolute;
            color: #FF1493;
            pointer-events: none;
            animation: rise 5s infinite ease-in;
            opacity: 0;
            z-index: 0;
        }

        @keyframes rise {
            0% {
                transform: translateY(100vh) scale(0.5);
                opacity: 0;
            }

            100% {
                transform: translateY(-10vh) scale(1.2);
                opacity: 0;
            }
        }

        .glass-header {
            background: rgba(10, 5, 20, 0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .glass-input {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .msg-bubble {
            max-width: 85%;
            border-radius: 18px;
            padding: 6px 16px;
            position: relative;
            animation: fadeIn 0.3s ease-out;
            letter-spacing: -0.01em;
        }

        .msg-left {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-bottom-left-radius: 5px;
        }

        .msg-right {
            background: linear-gradient(135deg, #f02d66, #9333EA);
            border-bottom-right-radius: 5px;
            box-shadow: 0 8px 20px rgba(225, 29, 72, 0.15);
        }

        .pulse-dots span {
            width: 4px;
            height: 4px;
            background: #6B7280;
            border-radius: 50%;
            display: inline-block;
            animation: blink 1.4s infinite ease-in-out;
        }

        .pulse-dots span:nth-child(2) {
            animation-delay: 0.2s;
        }

        .pulse-dots span:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes blink {

            0%,
            100% {
                opacity: 0.2;
                transform: scale(0.8);
            }

            50% {
                opacity: 1;
                transform: scale(1.2);
            }
        }

        .reaction-overlay {
            position: absolute;
            top: -50px;
            background: rgba(26, 11, 54, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 100px;
            padding: 6px 12px;
            display: flex;
            gap: 8px;
            border: 1px solid rgba(225, 29, 72, 0.4);
            z-index: 10;
            animation: bounceIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes bounceIn {
            from {
                opacity: 0;
                transform: translateY(10px) scale(0.8);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        #chat-container::-webkit-scrollbar {
            display: none;
        }

        #chat-container {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .bg-btn-gradient {
            background: linear-gradient(135deg, #f02d66, #9333EA);
        }

        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>

<body class="bg-[#0a0514] text-white flex flex-col h-screen overflow-hidden font-sans">

    <!-- Animated Heart Background -->
    <div id="heart-container" class="fixed inset-0 overflow-hidden pointer-events-none z-0"></div>

    <!-- Top Chat Header -->
    <header class="glass-header z-50 px-4 py-3 flex flex-col space-y-1">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <a href="/home" class="p-2 hover:bg-white/5 rounded-full text-gray-400 transition-colors"><i
                        class="fas fa-chevron-left text-xl"></i></a>
                <div class="relative group cursor-pointer" onclick="vibrateDevice()">
                    <img src="/images/partner-avatar.png" alt="Partner"
                        class="w-12 h-12 rounded-full border-2 border-brand-pink p-0.5">
                    <div id="online-indicator"
                        class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 rounded-full border-2 border-[#0a0514]"></div>
                </div>
                <div>
                    <h3 class="font-bold text-sm tracking-tight"><span id="header-partner-name">Partner</span> ❤️</h3>
                    <p id="status-text" class="text-[10px] font-black text-green-400 uppercase tracking-widest">Online</p>
                </div>
            </div>
            <div class="flex items-center space-x-2 text-gray-400">
                <!-- --- GHOST MODE TOGGLE --- -->
                <button id="ghost-toggle" onclick="toggleGhostMode()" 
                    class="p-2.5 rounded-full transition-all group relative <%= user.ghostMode ? 'text-brand-pink bg-brand-pink/10 animate-pulse' : 'hover:bg-white/5 hover:text-white' %>"
                    title="Toggle Invisible Mode">
                    <i class="fas fa-user-secret text-lg"></i>
                    <span id="ghost-status-dot" class="absolute top-1 right-1 w-2 h-2 rounded-full <%= user.ghostMode ? 'bg-brand-pink shadow-[0_0_8px_#ff007f]' : 'bg-gray-600' %>"></span>
                </button>
                
                <button onclick="initiateCall('video')" class="p-2.5 hover:bg-white/5 rounded-full hover:text-brand-pink transition-all"><i
                        class="fas fa-video text-lg"></i></button>
                <button onclick="initiateCall('voice')" class="p-2.5 hover:bg-white/5 rounded-full hover:text-brand-pink transition-all"><i
                        class="fas fa-phone-alt text-lg"></i></button>
                <button class="p-2.5 hover:bg-white/5 rounded-full hover:text-white transition-all"><i
                        class="fas fa-ellipsis-v"></i></button>
            </div>
        </div>
        <!-- --- OFFLINE SYNC NOTIFICATION --- -->
        <div id="offline-bar" class="hidden bg-orange-600/20 py-1.5 px-4 rounded-xl border border-orange-500/20 flex items-center justify-center space-x-2 animate-pulse overflow-hidden">
             <i class="fas fa-cloud-slash text-[10px] text-orange-400"></i>
             <span class="text-[8px] font-black text-white/80 uppercase tracking-[0.2em]">Sync Active: Messages will send when online 🕒</span>
        </div>
    </header>

    <!-- Call Overlay UI -->
    <div id="call-overlay"
        class="fixed inset-0 z-[100] hidden bg-black/90 backdrop-blur-xl flex flex-col items-center justify-center p-6 animate-in zoom-in duration-300">
        <!-- Remote Video (Full Screen) -->
        <video id="remote-video" autoplay playsinline
            class="absolute inset-0 w-full h-full object-cover opacity-80"></video>

        <!-- Local Video (Picture-in-Picture) -->
        <div
            class="absolute top-8 right-8 w-32 h-44 rounded-3xl overflow-hidden border-2 border-brand-pink shadow-2xl z-20 bg-gray-900">
            <video id="local-video" autoplay playsinline muted class="w-full h-full object-cover"></video>
        </div>

        <!-- Caller Info -->
        <div class="text-center z-10 mb-20 text-white">
            <div class="w-24 h-24 rounded-full border-4 border-brand-pink p-1 mx-auto mb-6">
                <img src="/images/partner-avatar.png" class="w-full h-full rounded-full object-cover">
            </div>
            <h2 id="calling-status" class="text-2xl font-black mb-2 uppercase tracking-widest animate-pulse">Ringing...
            </h2>
            <p class="text-xs font-black uppercase tracking-widest text-brand-pink">Partner</p>
        </div>

        <!-- Control Buttons -->
        <div class="z-10 flex items-center space-x-6">
            <button onclick="toggleMic()" id="mic-btn"
                class="w-16 h-16 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-xl transition-all hover:bg-white/20 active:scale-95">
                <i class="fas fa-microphone"></i>
            </button>
            <button onclick="hangupCall()"
                class="w-20 h-20 rounded-full bg-red-600 flex items-center justify-center text-2xl shadow-2xl transition-all hover:scale-110 active:scale-90 text-white">
                <i class="fas fa-phone-slash"></i>
            </button>
            <button onclick="toggleVideo()" id="video-btn"
                class="w-16 h-16 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-xl transition-all hover:bg-white/20 active:scale-95 text-white">
                <i class="fas fa-video"></i>
            </button>
        </div>

        <!-- Incoming Call UI -->
        <div id="incoming-call-box"
            class="hidden absolute bottom-20 left-1/2 -translate-x-1/2 w-80 bg-white/10 backdrop-blur-3xl border border-white/20 rounded-[2.5rem] p-6 shadow-2xl animate-in slide-in-from-bottom duration-500 z-[110]">
            <div class="text-center mb-6">
                <p class="text-[10px] font-black uppercase tracking-widest text-brand-pink mb-2">Incoming Call</p>
                <div class="w-20 h-20 rounded-full border-2 border-brand-pink p-1 mx-auto">
                    <img src="/images/partner-avatar.png" class="w-full h-full rounded-full">
                </div>
            </div>
            <div class="flex items-center space-x-4">
                <button onclick="rejectCall()"
                    class="flex-1 bg-red-600/20 text-red-500 py-4 rounded-2xl font-black uppercase text-[10px] tracking-widest border border-red-500/20">Decline</button>
                <button onclick="acceptCall()"
                    class="flex-1 bg-green-500 py-4 rounded-2xl font-black text-white uppercase text-[10px] tracking-widest shadow-lg shadow-green-500/30">Accept</button>
            </div>
        </div>
    </div>

    <!-- Chat Messages Scrolling Area -->
    <main id="chat-container"
        class="flex-grow overflow-y-auto px-4 py-10 flex flex-col space-y-6 relative z-10 scroll-smooth">
        <!-- Messages will be injected here -->

        <!-- Welcome Card -->
        <div class="mx-auto w-full max-w-[90%] md:max-w-xs text-center space-y-4 mb-4">
            <div class="glass-input p-5 md:p-6 rounded-3xl border-brand-pink/20">
                <div class="w-10 h-10 bg-brand-pink/20 rounded-full mx-auto flex items-center justify-center text-brand-pink mb-2">
                    <i class="fas fa-lock text-sm"></i>
                </div>
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest leading-relaxed">
                    Private & Secure Bond ❤️
                </p>
            </div>
        </div>

        <!-- Quiz Integration Card -->
        <div class="mx-auto w-full max-w-[95%] md:max-w-sm">
            <div class="glass-input p-5 md:p-6 border-brand-pink/40 bg-brand-pink/5 rounded-[2rem] relative overflow-hidden group">
                <div class="absolute -top-10 -right-10 w-24 h-24 bg-brand-pink/10 blur-2xl"></div>
                <div class="flex items-center space-x-4 mb-5">
                    <div class="w-10 h-10 flex-shrink-0 bg-brand-pink/20 rounded-xl flex items-center justify-center text-brand-pink border border-brand-pink/30">
                        <i class="fas fa-brain"></i>
                    </div>
                    <div>
                        <h4 class="font-black text-xs md:text-sm text-white uppercase tracking-wider">Tonight’s Quiz ❤️</h4>
                        <p class="text-[9px] text-gray-500 font-bold uppercase">Ready to Play</p>
                    </div>
                </div>
                <button onclick="startQuiz()"
                    class="w-full bg-brand-pink py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] shadow-lg shadow-brand-pink/20 transition-all hover:scale-[1.02] active:scale-95">
                    Start Game 🧠
                </button>
            </div>
        </div>

    </main>

    <!-- Typing Indicator -->
    <div id="typing-indicator"
        class="px-6 py-2 flex items-center space-x-2 text-[10px] font-black text-gray-500 uppercase tracking-widest hidden relative z-10">
        <span>Partner is typing</span>
        <div class="pulse-dots flex space-x-1 ml-1">
            <span></span><span></span><span></span>
        </div>
    </div>

    <!-- Message Input Space -->
    <footer class="p-4 bg-gradient-to-t from-[#0a0514] to-transparent relative z-10">

        <!-- Quick Suggestions -->
        <div class="flex space-x-2 mb-4 overflow-x-auto no-scrollbar pb-1">
            <div class="flex space-x-2" id="suggestion-bar">
                <button onclick="sendQuickLove('Thinking of you... 💭')"
                    class="whitespace-nowrap bg-white/5 border border-white/10 px-4 py-2 rounded-xl text-[10px] font-bold text-gray-400 hover:bg-brand-pink hover:text-white hover:border-brand-pink transition-all">Thinking
                    of you... 💭</button>
                <button onclick="sendQuickLove('Send me a selfie? 📸')"
                    class="whitespace-nowrap bg-white/5 border border-white/10 px-4 py-2 rounded-xl text-[10px] font-bold text-gray-400 hover:bg-brand-pink hover:text-white hover:border-brand-pink transition-all">Send
                    me a selfie? 📸</button>
                <button onclick="sendQuickLove('I love you! ❤️')"
                    class="whitespace-nowrap bg-white/5 border border-white/10 px-4 py-2 rounded-xl text-[10px] font-bold text-gray-400 hover:bg-brand-pink hover:text-white hover:border-brand-pink transition-all">I
                    love you! ❤️</button>
                <button onclick="sendQuickLove('Can we talk? 📞')"
                    class="whitespace-nowrap bg-white/5 border border-white/10 px-4 py-2 rounded-xl text-[10px] font-bold text-gray-400 hover:bg-brand-pink hover:text-white hover:border-brand-pink transition-all">Can
                    we talk? 📞</button>

                <!-- Suggestions will be injected here -->
            </div>
        </div>

        <!-- Input Outer Shell -->
        <div class="max-w-4xl mx-auto space-y-4">

        <!-- Quick Love Actions -->
        <div class="flex justify-center space-x-2 md:space-x-3 overflow-x-auto no-scrollbar py-2">
            <button onclick="sendQuickLove('❤️ MISS YOU')"
                class="flex-shrink-0 bg-white/5 border border-white/10 px-3 md:px-5 py-2.5 rounded-full text-[9px] md:text-[10px] font-black uppercase text-brand-pink hover:bg-brand-pink hover:text-white transition-all">❤️ Miss you</button>
            <button onclick="sendQuickLove('😘 KISS')"
                class="flex-shrink-0 bg-white/5 border border-white/10 px-3 md:px-5 py-2.5 rounded-full text-[9px] md:text-[10px] font-black uppercase text-brand-pink hover:bg-brand-pink hover:text-white transition-all">😘 Kiss</button>
            <button onclick="sendQuickLove('🤗 HUG')"
                class="flex-shrink-0 bg-white/5 border border-white/10 px-3 md:px-5 py-2.5 rounded-full text-[9px] md:text-[10px] font-black uppercase text-brand-pink hover:bg-brand-pink hover:text-white transition-all">🤗 Hug</button>
        </div>

            <!-- Real Input Area -->
            <div class="flex items-center glass-input p-1.5 rounded-full relative shadow-2xl">
                <button class="w-10 h-10 flex-shrink-0 text-gray-400 hover:text-brand-pink transition-colors flex items-center justify-center">
                    <i class="fas fa-plus text-sm"></i>
                </button>
                
                <input type="text" id="chatInput" placeholder="Type a message..."
                    class="bg-transparent flex-grow outline-none text-sm font-medium py-2 px-1 min-w-0">

                <div class="flex items-center border-l border-white/10 px-1 space-x-0.5">
                    <button onclick="openCamera()" class="w-10 h-10 flex-shrink-0 text-gray-400 hover:text-white transition-colors flex items-center justify-center"
                        title="Send Snap"><i class="fas fa-camera text-sm"></i></button>
                    <button id="mic-btn" onmousedown="startRecording()" onmouseup="stopRecording()"
                        ontouchstart="startRecording()" ontouchend="stopRecording()"
                        class="w-10 h-10 flex-shrink-0 text-gray-400 hover:text-white transition-colors flex items-center justify-center" title="Voice Note">
                        <i class="fas fa-microphone text-sm"></i>
                    </button>
                </div>

                <button id="send-btn" onclick="sendMessage()"
                    class="bg-btn-gradient w-11 h-11 flex-shrink-0 rounded-full flex items-center justify-center shadow-lg hover:scale-105 active:scale-95 transition-all ml-1">
                    <i class="fas fa-paper-plane text-sm"></i>
                </button>
            </div>
        </div>
    </footer>


    <!-- Camera Overlay -->
    <div id="camera-modal" class="fixed inset-0 z-[100] bg-black/95 hidden grid place-items-center p-4">
        <div
            class="relative w-full max-w-lg aspect-[3/4] rounded-[3rem] overflow-hidden bg-[#1a1326] shadow-2xl border border-white/10">
            <video id="camera-preview" autoplay playsinline class="w-full h-full object-cover"></video>
            <div id="flash" class="absolute inset-0 bg-white hidden z-20"></div>

            <button onclick="closeCamera()"
                class="absolute top-8 left-8 w-12 h-12 rounded-full bg-black/40 backdrop-blur-md flex items-center justify-center text-white z-30">
                <i class="fas fa-times"></i>
            </button>

            <div class="absolute bottom-12 inset-x-0 flex items-center justify-center z-30">
                <button id="capture-btn"
                    class="w-20 h-20 rounded-full border-4 border-white flex items-center justify-center group active:scale-90 transition-all">
                    <div class="w-16 h-16 rounded-full bg-white group-hover:scale-105 transition-all"></div>
                </button>
            </div>
        </div>
        <canvas id="photo-canvas" class="hidden"></canvas>
    </div>


    <!-- Voice Recording Overlay -->
    <div id="voice-modal" class="hidden fixed inset-0 z-[200] bg-black/90 backdrop-blur-3xl">
        <div class="flex flex-col items-center justify-center w-full h-full text-center space-y-12">
            <div class="relative w-48 h-48 flex items-center justify-center">
                <div class="absolute inset-0 bg-brand-pink/20 rounded-full animate-ping"></div>
                <div
                    class="w-24 h-24 bg-brand-pink rounded-full flex items-center justify-center text-white shadow-[0_0_80px_rgba(255,0,127,0.6)] z-10 transition-transform scale-110">
                    <i class="fas fa-microphone text-4xl"></i>
                </div>
            </div>

            <div class="space-y-4">
                <h3 class="text-3xl font-black italic text-white uppercase tracking-wider animate-pulse">Recording...
                </h3>
                <p id="timer" class="text-brand-pink font-black text-xl tracking-[0.2em]">00:00</p>
                <p
                    class="text-gray-500 text-[10px] font-bold uppercase tracking-widest bg-white/5 py-2 px-4 rounded-full">
                    Keep holding to record ❤️</p>
            </div>

            <div class="flex space-x-4">
                <button onclick="cancelRecording()"
                    class="px-8 py-4 bg-white/5 rounded-full border border-white/10 text-[10px] font-black uppercase text-gray-400 hover:text-white transition-all">Cancel</button>
                <div
                    class="px-8 py-4 bg-brand-pink/20 rounded-full border border-brand-pink/40 text-[10px] font-black uppercase text-brand-pink">
                    Release to Send 🏹</div>
            </div>
        </div>
    </div>

    <script>
        function createNoopSocket() {
            return {
                on: () => { },
                emit: () => { },
                connected: false
            };
        }

        function createSocketClient() {
            if (typeof io !== 'function') return createNoopSocket();
            try {
                const s = io({
                    path: '/socket.io',
                    transports: ['websocket'],
                    upgrade: false,
                    withCredentials: true,
                    reconnection: true,
                    reconnectionAttempts: 5,
                    timeout: 10000
                });

                s.on('connect_error', (err) => {
                    console.warn('Realtime temporarily unavailable:', err.message);
                });
                return s;
            } catch (err) {
                console.warn('Socket init failed:', err.message);
                return createNoopSocket();
            }
        }

        const socket = createSocketClient();
        const chatContainer = document.getElementById('chat-container');
        const msgInput = document.getElementById('chatInput');
        const sendBtn = document.getElementById('send-btn');
        const typingIndicator = document.getElementById('typing-indicator');

        // --- NEW: SEND ON ENTER ---
        msgInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        let USER_ID = "<%= user._id %>";
        let USER_NAME = "<%= user.name %>";
        let PARTNER_ID, COUPLE_ID;

        // --- WebRTC Calling Logic ---
        let localStream;
        let peerConnection;
        let isCalling = false;
        const config = { iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] };

        async function startCall(type) {
            if (isCalling) return;
            isCalling = true;
            document.getElementById('call-overlay').classList.remove('hidden');
            document.getElementById('calling-status').innerText = "Ringing...";
            try {
                localStream = await navigator.mediaDevices.getUserMedia({ video: type === 'video', audio: true });
                document.getElementById('local-video').srcObject = localStream;
                peerConnection = new RTCPeerConnection(config);
                localStream.getTracks().forEach(track => peerConnection.addTrack(track, localStream));
                peerConnection.onicecandidate = (e) => { if (e.candidate) socket.emit('ice-candidate', { coupleId: COUPLE_ID, candidate: e.candidate }); };
                peerConnection.ontrack = (e) => { document.getElementById('remote-video').srcObject = e.streams[0]; document.getElementById('calling-status').innerText = "Connected"; };
                const offer = await peerConnection.createOffer();
                await peerConnection.setLocalDescription(offer);
                socket.emit('call-user', { coupleId: COUPLE_ID, offer, from: USER_ID, type });
            } catch (err) { hangupCall(); }
        }

        socket.on('incoming-call', (data) => {
            document.getElementById('call-overlay').classList.remove('hidden');
            document.getElementById('incoming-call-box').classList.remove('hidden');
            window.incomingCallData = data;
        });

        async function acceptCall() {
            const data = window.incomingCallData;
            document.getElementById('incoming-call-box').classList.add('hidden');
            try {
                localStream = await navigator.mediaDevices.getUserMedia({ video: data.type === 'video', audio: true });
                document.getElementById('local-video').srcObject = localStream;
                peerConnection = new RTCPeerConnection(config);
                localStream.getTracks().forEach(track => peerConnection.addTrack(track, localStream));
                peerConnection.onicecandidate = (e) => { if (e.candidate) socket.emit('ice-candidate', { coupleId: COUPLE_ID, candidate: e.candidate }); };
                peerConnection.ontrack = (event) => { document.getElementById('remote-video').srcObject = event.streams[0]; document.getElementById('calling-status').innerText = "Connected"; };
                await peerConnection.setRemoteDescription(new RTCSessionDescription(data.offer));
                const answer = await peerConnection.createAnswer();
                await peerConnection.setLocalDescription(answer);
                socket.emit('answer-call', { coupleId: COUPLE_ID, answer });
            } catch (err) { hangupCall(); }
        }

        socket.on('call-answered', async (data) => { await peerConnection.setRemoteDescription(new RTCSessionDescription(data.answer)); });
