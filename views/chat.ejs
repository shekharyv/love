        async function startAgoraCall(channelName, type) {
            const overlay = document.getElementById('call-overlay');
            overlay.classList.remove('hidden');
            document.getElementById('calling-status').innerText = "Connecting...";

            try {
                const res = await fetch(`/api/agora-token?channelName=${channelName}&uid=0`);
                const { token, appId } = await res.json();
                
                await agoraClient.join(appId, channelName, token, null);
                
                localTracks.audioTrack = await AgoraRTC.createMicrophoneAudioTrack();
                if (type === 'video') {
                    localTracks.videoTrack = await AgoraRTC.createCameraVideoTrack();
                    localTracks.videoTrack.play('local-video');
                    await agoraClient.publish([localTracks.audioTrack, localTracks.videoTrack]);
                } else {
                    await agoraClient.publish([localTracks.audioTrack]);
                    document.getElementById('local-video-container').innerHTML = `<div class="w-full h-full flex items-center justify-center bg-gray-900"><i class="fas fa-microphone text-4xl text-brand-pink"></i></div>`;
                }

                document.getElementById('calling-status').innerText = "Connected";
                startCallTimer();

                // Network Quality Monitoring
                agoraClient.on("network-quality", (quality) => {
                    const bars = document.getElementById('network-status').children;
                    const q = quality.downlinkNetworkQuality; 
                    for(let i=0; i<3; i++) {
                        bars[i].className = `w-0.5 rounded-full ${i+1 <= (4-q) ? 'bg-green-500' : 'bg-white/20'}`;
                        bars[i].style.height = `${(i+1)*4}px`;
                    }
                });

                agoraClient.on("user-published", async (user, mediaType) => {
                    await agoraClient.subscribe(user, mediaType);
                    if (mediaType === "video") user.videoTrack.play('remote-video');
                    if (mediaType === "audio") user.audioTrack.play();
                });
            } catch (err) { 
                console.error("Agora Error:", err);
                hangupCall(); 
            }
        }

        async function hangupCall() {
            for (let trackName in localTracks) {
                if (localTracks[trackName]) {
                    localTracks[trackName].stop();
                    localTracks[trackName].close();
                    localTracks[trackName] = null;
                }
            }
            await agoraClient.leave();
            stopCallTimer();
            ringtone.pause();
            ringtone.currentTime = 0;
            document.getElementById('call-overlay').classList.add('hidden');
            socket.emit('end-call', { to: PARTNER_ID });
        }

