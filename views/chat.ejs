        function getStatusIcon(status) {
            if (status === 'seen') return '<i class="fas fa-check-double text-[#FFD700] drop-shadow-[0_0_8px_rgba(255,215,0,0.6)] scale-110"></i>';
            if (status === 'delivered') return '<i class="fas fa-check-double text-white/40"></i>';
            if (status === 'sent') return '<i class="fas fa-check text-white/40"></i>';
            return '<i class="fas fa-clock text-white/20 animate-pulse"></i>';
        }

        function getRelativeSeenTime(seenAt) {
            if (!seenAt) return "Just now";
            const date = new Date(seenAt);
            if (isNaN(date.getTime())) return "Now";
            const diff = (new Date() - date) / 1000;
            if (diff < 60) return "Just now";
            if (diff < 3600) return Math.floor(diff / 60) + "m ago";
            return date.getHours() + ":" + date.getMinutes().toString().padStart(2, '0');
        }


